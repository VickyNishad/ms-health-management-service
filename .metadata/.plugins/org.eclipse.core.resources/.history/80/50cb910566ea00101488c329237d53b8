	public String generateSlot(String profileId, String addressId, String date) {
		try {

			Map<String, Object> slotReq = new HashMap<>();
			slotReq.put("p_profile_id", profileId);
			slotReq.put("p_address_id", addressId);
			slotReq.put("p_target_date", date);

			Map<String, Object> slotRes = tRepository.execute(slotReq, "", "USP_InsertDoctorSlotsForDate");

			logger.info("JobSchedular slotRes information : {}", slotRes);

		} catch (Exception e) {
			// TODO: handle exception
			return e.getLocalizedMessage();
		}
		return "slot generate successfuly.";
