    private final UpdateAddressServiceImpl updateAddressServiceImpl;
	private static final Logger logger = LoggerFactory.getLogger(JobSchedular.class);

	@Autowired
	private TRepository tRepository;

    JobSchedular(UpdateAddressServiceImpl updateAddressServiceImpl) {
        this.updateAddressServiceImpl = updateAddressServiceImpl;
    }

	@SuppressWarnings("unchecked")
	@Async
	public void generateSlot() {

		try {
			Map<String, Object> misReq = new HashMap<>();
			misReq.put("p_days", 7);
			Map<String, Object> misRes = tRepository.execute(misReq, "", "USP_GetMissingDoctorSlots");

			logger.info("JobSchedular misRes information : {}", misRes);

			List<Map<String, Object>> misList = (List<Map<String, Object>>) misRes
					.get(TConstants.ResultSet.RESULT_SET_1);

			if (misList.size() > 0) {
				for (Map<String, Object> ms : misList) {

					System.out.println("generate slot from : " + ms);

					Map<String, Object> slotReq = new HashMap<>();
					slotReq.put("p_profile_id", TUtils.getStringValue(ms.get("ProfileId")));
					slotReq.put("p_address_id", TUtils.getStringValue(ms.get("AddressId")));
					slotReq.put("p_target_date", TUtils.getStringValue(ms.get("MissingDate")));

					try {
						Map<String, Object> slotRes = tRepository.execute(slotReq, "", "USP_InsertDoctorSlotsForDate");

						logger.info("JobSchedular slotRes information : {}", slotRes);
					} catch (Exception e) {
						// TODO: handle exception
						logger.info("Exception : ", e.getMessage());
					}

				}
			}

		} catch (Exception e) {
			// TODO: handle exception
			logger.error("JobSchedular slotRes information : {}", e.getMessage());
		}
	}

