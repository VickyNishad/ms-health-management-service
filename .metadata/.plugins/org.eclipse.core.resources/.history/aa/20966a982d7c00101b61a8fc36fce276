package com.document.service;

import java.util.UUID;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;
import org.springframework.web.multipart.MultipartFile;

import com.document.config.S3BucketPro;
import com.document.interfaces.AbstractUseCase;
import com.document.models.GenericModel;
import com.document.models.request.DBProcedureRequest;
import com.document.models.request.S3BucketRequest;

import software.amazon.awssdk.core.sync.RequestBody;
import software.amazon.awssdk.services.s3.S3Client;
import software.amazon.awssdk.services.s3.model.PutObjectRequest;

/**
 * 
 */
@Service
public class S3BucketServiceImpl extends AbstractUseCase<S3BucketRequest, DBProcedureRequest, ResponseEntity<?>> {
	
	private final S3BucketPro s3BucketPro;
    private S3Client s3Client;
	
	public S3BucketServiceImpl(S3Client s3Client , S3BucketPro s3BucketPro) {
		this.s3Client = s3Client;
		this.s3BucketPro = s3BucketPro;
	}

	@Override
	protected ResponseEntity<?> validateInput(GenericModel<S3BucketRequest> model) {
		// TODO Auto-generated method stub
		return null;
	}

	@Override
	protected DBProcedureRequest buildDatabaseRequest(GenericModel<S3BucketRequest> model) {
		// TODO Auto-generated method stub
		DBProcedureRequest dbProcedureRequest = new DBProcedureRequest();
		return dbProcedureRequest;
	}

	@Override
	protected ResponseEntity<?> execute(GenericModel<S3BucketRequest> model, DBProcedureRequest dbRequest) {
		// TODO Auto-generated method stub
		return new ResponseEntity<>(HttpStatus.OK);
	}

	@Override
	protected ResponseEntity<?> buildFinalResponse(GenericModel<S3BucketRequest> model, ResponseEntity<?> result) {
		// TODO Auto-generated method stub
		try {
			S3BucketRequest s3BucketRequest = model.getPayload();
			MultipartFile file = s3BucketRequest.getMultipartFile();
			
			  String fileName = UUID.randomUUID() + "_" + file.getOriginalFilename();

		        // This holds metadata about the file being uploaded (like bucket, key, and content type)
		        PutObjectRequest putObjectRequest = PutObjectRequest.builder()
		                .bucket(bucketName)                   // Target S3 bucket name
		                .key(fileName)                        // Object key (filename) in the bucket
		                .contentType(file.getContentType())   // Optional: sets the MIME type (e.g., image/jpeg, application/pdf)
		                .build();

		     // We pass in the request and the file content (converted to byte array)
		        s3Client.putObject(
		            putObjectRequest,
		            RequestBody.fromBytes(file.getBytes())    // Converts MultipartFile to byte array for upload
		        );

		        return fileName; 
			
		} catch (Exception e) {
			// TODO: handle exception
		}
		return null;
	}

}
