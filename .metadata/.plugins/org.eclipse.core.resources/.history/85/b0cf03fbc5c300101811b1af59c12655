package com.healthcare.schedular;

import java.util.HashMap;
import java.util.List;
import java.util.Map;

import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.scheduling.annotation.Async;
import org.springframework.stereotype.Service;

import com.healthcare.constant.TConstants;
import com.healthcare.interfaces.TRepository;
import com.healthcare.utils.TUtils;

/**
 * 
 */
@Service
public class JobSchedular {
	private static final Logger logger = LoggerFactory.getLogger(JobSchedular.class);
	
	@Autowired
	private TRepository tRepository;

	@Async 
	public void generateSlot() {

		try {
			Map<String, Object> misReq = new HashMap<>();
			misReq.put("p_days", 7);
			Map<String, Object> misRes = tRepository.execute(misReq, "", "USP_GetMissingDoctorSlots");

			logger.info("JobSchedular misRes information : {}", misRes);

			List<Map<String, Object>> misList = (List<Map<String, Object>>) misRes.get(TConstants.ResultSet.RESULT_SET_1);

			if (misList.size() > 0) {
				for(Map<String, Object> ms : misList) {				
					Map<String, Object> slotReq = new HashMap<>();
					slotReq.put("p_ProfileId", TUtils.getStringValue(ms.get("ProfileId")));
					slotReq.put("p_AddressId", TUtils.getStringValue(ms.get("AddressId")));
					slotReq.put("p_SlotDate", TUtils.getStringValue(ms.get("slot_date")));
					slotReq.put("p_SlotStartTime", TUtils.getStringValue(ms.get("SlotStartTime")));
					slotReq.put("p_SlotEndTime", TUtils.getStringValue(ms.get("SlotEndTime")));
					slotReq.put("p_DurationMinutes", TUtils.getStringValue(ms.get("DurationMinutes")));

					Map<String, Object> slotRes = tRepository.execute(slotReq, "", "USP_InsertDoctorSlotsForDate");

					logger.info("JobSchedular slotRes information : {}", slotRes);
				}
			}

		} catch (Exception e) {
			// TODO: handle exception
			logger.error("JobSchedular slotRes information : {}", e.getMessage());
		}
	}
}
