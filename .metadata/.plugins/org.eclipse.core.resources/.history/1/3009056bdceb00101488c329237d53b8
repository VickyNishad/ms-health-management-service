package com.health.adapter.out.persistence;

import java.util.List;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

import com.health.adapter.out.persistence.entity.SpecializationMaster;
import com.health.adapter.out.persistence.jpa.JPASpecializationMasterRepository;
import com.health.application.port.out.SpecializationMasterRepositoryPort;

/**
 * 
 */
@Component
public class SpecializationMasterRepositoryAdapter implements SpecializationMasterRepositoryPort {
	
	@Autowired
	private JPASpecializationMasterRepository specializationMasterRepository;

	@Override
	public List<SpecializationMaster> findAllById(List<Long> id) {
		// TODO Auto-generated method stub
		return specializationMasterRepository.findAllById(id);
	}

}
