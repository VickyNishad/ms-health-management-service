package com.healthcare.controller;

import org.springdoc.core.annotations.ParameterObject;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.CrossOrigin;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.healthcare.interfaces.ManageDoctorUseCase;
import com.healthcare.interfaces.ManageStaffUseCase;
import com.healthcare.interfaces.usecase.CallNextPatientUseCase;
import com.healthcare.interfaces.usecase.CreateDoctorProfileUseCase;
import com.healthcare.interfaces.usecase.GetSlotUseCase;
import com.healthcare.interfaces.usecase.GetTodaysAppointmentUseCase;
import com.healthcare.interfaces.usecase.StaffRegistraionUseCase;
import com.healthcare.models.GenericRequestModel;
import com.healthcare.models.request.AddressRegistration;
import com.healthcare.models.request.DoctorAvailabilityFilter;
import com.healthcare.models.request.DoctorAvailabilityRequest;
import com.healthcare.models.request.DoctorNextPatientRequest;
import com.healthcare.models.request.DoctorRegistration;
import com.healthcare.models.request.DoctorSearchRequest;
import com.healthcare.models.request.FilterRequest;
import com.healthcare.models.request.SlotRequest;
import com.healthcare.models.request.StaffRegistraion;
import com.healthcare.models.request.StaffRequest;
import com.healthcare.models.request.UpdateAddressRequest;
import com.healthcare.models.request.UpdateStaffByCreatorRequest;
import com.healthcare.schedular.JobSchedular;
import com.healthcare.service.DoctorAvailabilityServiceImpl;
import com.healthcare.service.ManageSearchService;
import com.healthcare.utils.TUtils;
import jakarta.servlet.http.HttpServletRequest;

/**
 * 
 */
@CrossOrigin(origins = "*", allowedHeaders = "*")
@RestController
@RequestMapping(AuthController.BASE_URL+DoctorController.BASE_URL)
public class DoctorController {

	public static final String BASE_URL = "/doctor";

	private GetSlotUseCase getSlotUseCase;

	private CallNextPatientUseCase callNextPatientUseCase;

	private GetTodaysAppointmentUseCase getTodaysAppointmentUseCase;

	private StaffRegistraionUseCase staffRegistraionUseCase;

	private ManageDoctorUseCase manageDoctorUseCase;
	private ManageStaffUseCase manageStaffUseCase;
	private DoctorAvailabilityServiceImpl doctorAvailabilityServiceImpl;
	private ManageSearchService manageSearchService;
	private JobSchedular jobSchedular;

	public DoctorController(GetSlotUseCase getSlotUseCase, CreateDoctorProfileUseCase createDoctorProfileUseCase,
			CallNextPatientUseCase callNextPatientUseCase,
			GetTodaysAppointmentUseCase getTodaysAppointmentUseCase, StaffRegistraionUseCase staffRegistraionUseCase,
			ManageDoctorUseCase manageDoctorUseCase, ManageStaffUseCase manageStaffUseCase,
			DoctorAvailabilityServiceImpl doctorAvailabilityServiceImpl, ManageSearchService manageSearchService,
			JobSchedular jobSchedular) {

		this.getSlotUseCase = getSlotUseCase;
		this.callNextPatientUseCase = callNextPatientUseCase;
		this.getTodaysAppointmentUseCase = getTodaysAppointmentUseCase;
		this.staffRegistraionUseCase = staffRegistraionUseCase;
		this.manageDoctorUseCase = manageDoctorUseCase;
		this.manageStaffUseCase = manageStaffUseCase;
		this.doctorAvailabilityServiceImpl = doctorAvailabilityServiceImpl;
		this.manageSearchService = manageSearchService;
		this.jobSchedular = jobSchedular;
	}

	@PostMapping("/call/next-patient")
	public ResponseEntity<?> callNextPatient(@ParameterObject DoctorNextPatientRequest doctorNextPatientRequest, HttpServletRequest request){
		return callNextPatientUseCase.handle(TUtils.getObjectFromRequest(doctorNextPatientRequest, request));
	}
	
	@PostMapping("/profile/create")
	public ResponseEntity<?> createDoctorProfile(@RequestBody DoctorRegistration doctorRegistration, HttpServletRequest request) {
//	    return createDoctorProfileUseCase.handle(TUtils.getObjectFromRequest(doctorRegistration, request));
		return manageDoctorUseCase.insertDoctorProfile(TUtils.getObjectFromRequest(doctorRegistration, request));
	}
	
	@PostMapping("/staff/profile/create")
	public ResponseEntity<?> createStaffProfile(@RequestBody StaffRegistraion staffRegistraion, HttpServletRequest request) {
	    return staffRegistraionUseCase.handle(TUtils.getObjectFromRequest(staffRegistraion, request));
	}
	
	@PostMapping("/availability")
	public ResponseEntity<?> insertDoctorAvailability(@RequestBody DoctorAvailabilityRequest doctorAvailabilityRequest, HttpServletRequest request) {
		jobSchedular.generateSlot();
		return doctorAvailabilityServiceImpl.insert(TUtils.getObjectFromRequest(doctorAvailabilityRequest, request));
	}
	
	@GetMapping("/availability")
	public ResponseEntity<?> getDoctorAvailability(@ParameterObject DoctorAvailabilityFilter doctorAvailabilityFilter, HttpServletRequest request) {
//		jobSchedular.generateSlot();
		return doctorAvailabilityServiceImpl.get(TUtils.getObjectFromRequest(doctorAvailabilityFilter, request));
	}
	
	@PostMapping("/address/insert-details")
	public ResponseEntity<?> insertAddress( @RequestBody GenericRequestModel<AddressRegistration> genericRequestModel, HttpServletRequest request) {
//	    return insertAddressUseCase.handle(TUtils.getObjectFromRequest(genericRequestModel, request));
		return manageDoctorUseCase.insertDoctorClinic(TUtils.getObjectFromRequest(genericRequestModel, request));
	}
	
	@PostMapping("/address/update-details")
	public ResponseEntity<?> updateAddress( @RequestBody GenericRequestModel<UpdateAddressRequest> genericRequestModel, HttpServletRequest request) {
//	    return updateAddressUseCase.handle(TUtils.getObjectFromRequest(genericRequestModel, request));
		return manageDoctorUseCase.updateDoctorClinic(TUtils.getObjectFromRequest(genericRequestModel, request));
	}
	
	@GetMapping("/address/get-details")
	public ResponseEntity<?> getAddress( HttpServletRequest request) {
//	    return getAddressDetailsUseCase.handle(TUtils.getObjectFromRequest("", request));
		return manageDoctorUseCase.getDoctorClinics(TUtils.getObjectFromRequest("", request));
	}

	@GetMapping("/profile/get-details")
	public ResponseEntity<?> getDoctorProfile( HttpServletRequest request) {
//	    return getDoctorDetailsUseCase.handle(TUtils.getObjectFromRequest("", request));
		return manageDoctorUseCase.getDoctorProfile(TUtils.getObjectFromRequest("", request));
	}

	@GetMapping("/list")
	public ResponseEntity<?> getDoctorList(@ParameterObject DoctorSearchRequest doctorSearchRequest, HttpServletRequest request) {
		return manageSearchService.searchDoctor(TUtils.getObjectFromRequest(doctorSearchRequest, request));
	}
	
	@GetMapping("/today-appointments")
	public ResponseEntity<?> getTodaysAppointment(HttpServletRequest request) {
//	    return getTodaysAppointmentUseCase.handle(TUtils.getObjectFromRequest("", request));
		return manageDoctorUseCase.getTodaysAppointment(TUtils.getObjectFromRequest("", request));
	}
	
	@GetMapping("/get-slot")
	public ResponseEntity<?> getDoctorSlot(@ParameterObject SlotRequest slotRequest , HttpServletRequest request) {
	    return getSlotUseCase.handle(TUtils.getObjectFromRequest(slotRequest, request));
	}
	
	@GetMapping("/get-dashboard")
	public ResponseEntity<?> getDashboard(@ParameterObject FilterRequest filterRequest ,HttpServletRequest request) {
	    return manageDoctorUseCase.getDashboard(TUtils.getObjectFromRequest(filterRequest, request));
	}
	
	@GetMapping("/total-appointments")
	public ResponseEntity<?> getAppointments(@ParameterObject FilterRequest filterRequest,HttpServletRequest request) {
	    return manageDoctorUseCase.getAppointments(TUtils.getObjectFromRequest(filterRequest, request));
	}
	
	@GetMapping("/get-clinics")
	public ResponseEntity<?> getClinics(HttpServletRequest request) {
	    return manageDoctorUseCase.getClinics(TUtils.getObjectFromRequest("", request));
	}
	
	@PostMapping("/add-staff")
	public ResponseEntity<?> add(@RequestBody StaffRequest staffRequest, HttpServletRequest request) {
	    return manageStaffUseCase.addSatff(TUtils.getObjectFromRequest(staffRequest, request));
	}
	
	@PostMapping("/update-staff")
	public ResponseEntity<?> updateStaff(@RequestBody UpdateStaffByCreatorRequest staffRequest, HttpServletRequest request) {
	    return manageStaffUseCase.updateSatffByCreator(TUtils.getObjectFromRequest(staffRequest, request));
	}
	@GetMapping("/get-staff")
	public ResponseEntity<?> getSatff(HttpServletRequest request) {
	    return manageStaffUseCase.getSatff(TUtils.getObjectFromRequest("", request));
	}

	@GetMapping("/get-recommended")
	public ResponseEntity<?> getRecommendedDoctor(HttpServletRequest request) {
	    return manageDoctorUseCase.getRecommendedDoctor(TUtils.getObjectFromRequest("", request));
	}
	
	@GetMapping("/dashboard/get-medique-products")
	public ResponseEntity<?> getMediqueProducts(HttpServletRequest request) {
	    return manageDoctorUseCase.getMediqueProducts(TUtils.getObjectFromRequest("", request));
	}
}
