package com.health.repository.impl;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

import com.health.model.QualificationMaster;
import com.health.repository.QualificationMasterRepository;
import com.health.repository.jpa.JPAQualificationMasterRepository;



/**
 * 
 */
@Component
public class QualificationMasterRepositoryImpl implements QualificationMasterRepository {
	
	@Autowired
	private JPAQualificationMasterRepository qualificationMasterRepository;

	@Override
	public List<QualificationMaster> findAllById(List<Long> id) {
		// TODO Auto-generated method stub
		return qualificationMasterRepository.findAllById(id);
	}

}
