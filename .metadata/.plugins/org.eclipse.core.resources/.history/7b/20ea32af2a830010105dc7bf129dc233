package com.auth.service;

import java.nio.charset.StandardCharsets;
import java.util.Date;

import javax.crypto.SecretKey;

import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;

import com.auth.interfaces.TAbstractUseCase;
import com.auth.interfaces.usecase.AuthTokenUseCase;
import com.auth.interfaces.usecase.TUseCase;
import com.auth.models.GenericModel;
import com.auth.models.request.AuthTokenRequest;
import com.auth.models.request.DBProcedureRequest;
import com.auth.models.response.AuthTokenResponse;
import com.auth.models.response.ResponseModel;
import com.auth.utils.TConvertors;
import com.auth.utils.TUtils;

import io.jsonwebtoken.Jwts;
import io.jsonwebtoken.SignatureAlgorithm;
import io.jsonwebtoken.security.Keys;


/**
 * 
 */
@Service
public class AuthTokenServiceImpl extends TAbstractUseCase<AuthTokenRequest, DBProcedureRequest, ResponseEntity<?>> implements AuthTokenUseCase {
	private final String SECRET_KEY = "my-secret-key"; // 🔐 Use env var in real apps
	 private final long ACCESS_TOKEN_VALIDITY_MS = 5 * 60 * 1000;       // 5 minutes
	    private final long REFRESH_TOKEN_VALIDITY_MS = 24 * 60 * 60 * 1000; // 24 hours
	    private final SecretKey secretKey = Keys.hmacShaKeyFor(SECRET_KEY.getBytes(StandardCharsets.UTF_8));


	@Override
	protected ResponseEntity<?> validateInput(GenericModel<AuthTokenRequest> model) {
		// TODO Auto-generated method stub
		return new ResponseEntity<>(HttpStatus.OK);
	}

	@Override
	protected DBProcedureRequest buildDatabaseRequest(GenericModel<AuthTokenRequest> model) {
		// TODO Auto-generated method stub
		return new ResponseEntity<>(HttpStatus.OK);
	}

	@Override
	protected ResponseEntity<?> execute(GenericModel<AuthTokenRequest> model, DBProcedureRequest dbRequest) {
		// TODO Auto-generated method stub
		return null;
	}

	@Override
	protected ResponseEntity<?> buildFinalResponse(GenericModel<AuthTokenRequest> model, ResponseEntity<?> result) {
		// TODO Auto-generated method stub
		
		String json = TConvertors.convertObjectToString(model.getRequest());
		long now = System.currentTimeMillis();

        Date accessExpiry = new Date(now + ACCESS_TOKEN_VALIDITY_MS);
        Date refreshExpiry = new Date(now + REFRESH_TOKEN_VALIDITY_MS);

        // Generate Access Token
        String accessToken = Jwts.builder()
                .setSubject(json)
                .setIssuer("auth-service")
                .setIssuedAt(new Date(now))
                .setExpiration(accessExpiry)
                .signWith(secretKey, SignatureAlgorithm.HS256)
                .compact();

        // Generate Refresh Token
        String refreshToken = Jwts.builder()
                .setSubject(json)
                .setIssuer("auth-service")
                .setIssuedAt(new Date(now))
                .setExpiration(refreshExpiry)
                .signWith(secretKey, SignatureAlgorithm.HS256)
                .compact();

        // Prepare response
        
        AuthTokenResponse authTokenResponse = new AuthTokenResponse();
        authTokenResponse.setAccessToken(accessToken);
        authTokenResponse.setAccessTokenExpiresAt(TUtils.getStringValue(accessExpiry));
        authTokenResponse.setRefereshToken(refreshToken);
        authTokenResponse.setRefreshTokenExpiresAt(TUtils.getStringValue(refreshExpiry));
         
	    ResponseModel responseModel = new ResponseModel();
	    responseModel.setData(TUtils.getSuccess(authTokenResponse));
	    
		return new ResponseEntity<>(responseModel, HttpStatus.OK);
	}

	

}
