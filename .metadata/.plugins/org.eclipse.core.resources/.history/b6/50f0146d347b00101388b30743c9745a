    @Override
    protected ResponseEntity<?> validateInput(GenericModel<IsRegisterUserRequest> model) {
        IsRegisterUserRequest request = model.getPayload();
        if (request == null || request.getEmail() == null || request.getEmail().isEmpty()) {
            return ResponseEntity.badRequest().body("Email is required.");
        }
        if (!request.getEmail().contains("@")) {
            return ResponseEntity.badRequest().body("Email is invalid.");
        }
        return ResponseEntity.ok().build();
    }

    @Override
    protected DBProcedureRequest buildDatabaseRequest(GenericModel<IsRegisterUserRequest> model) {
        DBProcedureRequest request = new DBProcedureRequest();
        request.setTokenId(model.getToken());
        request.setParam_Process("IS_USER_REGISTERED");
//        request.setParam_JSON(new Gson().toJson(model.getPayload()));
        return request;
    }

