package com.healthcare.models.request;

import java.time.DayOfWeek;

public class WeeklySchedule {

    private DayOfWeek dayOfWeek;
    private int duration;
    private ShiftTime morning;
    private ShiftTime afternoon;
    private ShiftTime evening;

    // Getters and Setters
    public DayOfWeek getDayOfWeek() {
        return dayOfWeek;
    }

    public void setDayOfWeek(DayOfWeek dayOfWeek) {
        this.dayOfWeek = dayOfWeek;
    }

    public int getDuration() {
        return duration;
    }

    public void setDuration(int duration) {
        this.duration = duration;
    }

    public ShiftTime getMorning() {
        return morning;
    }

    public void setMorning(ShiftTime morning) {
        this.morning = morning;
    }

    public ShiftTime getAfternoon() {
        return afternoon;
    }

    public void setAfternoon(ShiftTime afternoon) {
        this.afternoon = afternoon;
    }

    public ShiftTime getEvening() {
        return evening;
    }

    public void setEvening(ShiftTime evening) {
        this.evening = evening;
    }
}