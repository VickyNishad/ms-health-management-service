package com.healthcare.controller;

import org.springdoc.core.annotations.ParameterObject;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.CrossOrigin;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.healthcare.interfaces.usecase.DoctorAvailabilityUseCase;
import com.healthcare.interfaces.usecase.GenerateSlotUseCase;
import com.healthcare.interfaces.usecase.GetDoctorAvailabilityUseCase;
import com.healthcare.interfaces.usecase.GetSlotUseCase;
import com.healthcare.models.request.DoctorAvailabilityRequest;
import com.healthcare.models.request.GetDoctorAvailabilityRequest;
import com.healthcare.utils.TUtils;

/**
 * 
 */
@CrossOrigin(origins = "*", allowedHeaders = "*")
@RestController
@RequestMapping(AuthController.BASE_URL+DoctorController.BASE_URL)
public class DoctorController {

	public static final String BASE_URL = "/doctor";
	
	private DoctorAvailabilityUseCase doctorAvailabilityUseCase;
	private GetDoctorAvailabilityUseCase getDoctorAvailabilityUseCase;
	private GenerateSlotUseCase generateSlotUseCase;
	private GetSlotUseCase getSlotUseCase;
	
	public DoctorController(
			DoctorAvailabilityUseCase doctorAvailabilityUseCase, GetDoctorAvailabilityUseCase getDoctorAvailabilityUseCase ,
			GenerateSlotUseCase generateSlotUseCase , GetSlotUseCase getSlotUseCase
			) {
		this.doctorAvailabilityUseCase = doctorAvailabilityUseCase;
		this.getDoctorAvailabilityUseCase = getDoctorAvailabilityUseCase;
		this.generateSlotUseCase = generateSlotUseCase;
		this.getSlotUseCase = getSlotUseCase;
	}
	
	@PostMapping("/availability")
	public ResponseEntity<?> doctorAvailabilityDetails(@RequestBody DoctorAvailabilityRequest doctorAvailabilityRequest){
		return doctorAvailabilityUseCase.apply(TUtils.getObjectFromRequest("", doctorAvailabilityRequest));
	}
	
	@GetMapping("/availability")
	public ResponseEntity<?> getAvailabilityDetails(@ParameterObject GetDoctorAvailabilityRequest getDoctorAvailabilityRequest){
		return getDoctorAvailabilityUseCase.apply(TUtils.getObjectFromRequest("", getDoctorAvailabilityRequest));
	}
	
	
	@GetMapping("/generate-slot")
	public ResponseEntity<?> generateSlot(@ParameterObject GetDoctorAvailabilityRequest getDoctorAvailabilityRequest){
		return getDoctorAvailabilityUseCase.apply(TUtils.getObjectFromRequest("", getDoctorAvailabilityRequest));
	}
	
	
	@GetMapping("/get-slot")
	public ResponseEntity<?> getSlotDetails(@ParameterObject GetDoctorAvailabilityRequest getDoctorAvailabilityRequest){
		return getDoctorAvailabilityUseCase.apply(TUtils.getObjectFromRequest("", getDoctorAvailabilityRequest));
	}
	
}
