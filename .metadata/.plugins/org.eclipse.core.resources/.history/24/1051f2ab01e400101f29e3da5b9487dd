	public ResponseEntity<?> getAreaMaster(String city){
		List<AreaMaster> list = areaMasterRepository.findByCityNameAndIsActiveTrue(city);
		return new ResponseEntity<>(list, HttpStatus.OK);
	}
	
	
	public ResponseEntity<?> getAreaMasterBySearch(String areaName){
		List<AreaMaster> list = areaMasterRepository.findByAreaNameContainingIgnoreCaseAndIsActiveTrue(areaName);
		return new ResponseEntity<>(list, HttpStatus.OK);
	}
	

	public ResponseEntity<?> findAllActiveCities(){
		List<String> list = areaMasterRepository.findAllActiveCities();
		return new ResponseEntity<>(list, HttpStatus.OK);
	}
	
	
	public ResponseEntity<?> findByPincode(String pincode){
		List<AreaMaster> list = areaMasterRepository.findByPincodeLike(pincode);
		return new ResponseEntity<>(list, HttpStatus.OK);
	}
	

