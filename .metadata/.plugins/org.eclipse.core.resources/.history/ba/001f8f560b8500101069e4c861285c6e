package com.gateway.config;

import org.springframework.cloud.gateway.route.RouteLocator;
import org.springframework.cloud.gateway.route.builder.RouteLocatorBuilder;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;

import com.gateway.filter.JwtAuthFilter;

/**
 * 
 */
@Configuration
public class GatewayConfig {
	
	private final JwtAuthFilter jwtAuthFilter;

    public GatewayConfig(JwtAuthFilter jwtAuthFilter) {
        this.jwtAuthFilter = jwtAuthFilter;
    }
	
	private static final String MS_BITTY_BRAIN_BASE_URL = "/api/v1/bittybrain/**";
	private static final String MS_DOCUMENT_SERVICE_BASE_URL = "/api/v1/document/**";
	

	@Bean
	public RouteLocator routeLocator(RouteLocatorBuilder builder) {
	    return builder.routes()
	      	            
	            .route("ms-document-service", r -> r.
	            		path(MS_DOCUMENT_SERVICE_BASE_URL)
	            		.filters(f -> f.filter(jwtAuthFilter.apply(new JwtAuthFilter.Config())))
	                    .uri("lb://ms-document-service")) 	            
	              
	            .route("ms-bitty-brain-service", r -> r
	            		.path(MS_BITTY_BRAIN_BASE_URL)
	            		.filters(f -> f.filter(jwtAuthFilter.apply(new JwtAuthFilter.Config())))
	                    .uri("lb://ms-bitty-brain-service"))
	            
	            .build();
	}


}
