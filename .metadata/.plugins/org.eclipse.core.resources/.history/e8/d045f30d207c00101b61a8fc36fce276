package com.document.controller;

import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.ModelAttribute;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;
import org.springframework.web.multipart.MultipartFile;

import com.document.interfaces.usecase.DocumetUploadUseCase;
import com.document.models.request.DocumentRequest;

/**
 * 
 */
@RestController
@RequestMapping("api/v1/document/file")
public class DocumentController {
	
	private DocumetUploadUseCase documetUploadUseCase;
	
	public DocumentController(DocumetUploadUseCase documetUploadUseCase) {
		this.documetUploadUseCase = documetUploadUseCase;
	}


	@PostMapping(value = "/upload", consumes = "multipart/form-data")
	public ResponseEntity<String> uploadDocument(@ModelAttribute DocumentRequest documentRequest) {
		MultipartFile file = documentRequest.getMultipartFile();

		// Validate & process the file and metadata
		System.out.println("File Name: " + documentRequest.getFileName());
		System.out.println("Reference ID: " + documentRequest.getReferenceId());
		System.out.println("Uploaded File: " + file.getOriginalFilename());

		// ... Upload to S3, call DB, etc.

		return ResponseEntity.ok("File uploaded successfully.");
	}

}
