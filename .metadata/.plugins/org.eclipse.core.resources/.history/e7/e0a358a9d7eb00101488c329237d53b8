package com.medicque.config;

import java.io.InputStream;

import org.springframework.core.io.ClassPathResource;
import org.springframework.stereotype.Component;

import com.fasterxml.jackson.databind.ObjectMapper;
import com.health.adapter.in.rest.dto.MenuConfig;

import jakarta.annotation.PostConstruct;

@Component
public class MenuConfigLoader {

    private MenuConfig menuConfig;

    @PostConstruct
    public void load() throws Exception {
        try {
            ObjectMapper mapper = new ObjectMapper();
            InputStream is = new ClassPathResource(
                "config/menu-config.json"
            ).getInputStream();

            menuConfig = mapper.readValue(is, MenuConfig.class);
        } catch (Exception e) {
            throw new RuntimeException("Failed to load menu-config.json", e);
        }
    }
    public MenuConfig getConfig() {
        return menuConfig;
    }
}
