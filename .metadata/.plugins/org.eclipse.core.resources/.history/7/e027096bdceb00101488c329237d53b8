package com.health.adapter.out.persistence;

import java.time.LocalDateTime;
import java.util.Optional;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

import com.health.adapter.out.persistence.entity.Doctor;
import com.health.adapter.out.persistence.jpa.JPADoctorRepository;
import com.health.application.port.out.DoctorRepositoryPort;
import com.health.domain.model.DoctorModel;

/**
 * 
 */
@Component
public class DoctorRepositoryAdapter implements DoctorRepositoryPort {
	
	@Autowired
	private JPADoctorRepository doctorRepository;

	@Override
	public Optional<Doctor> findById(Long id) {
		// TODO Auto-generated method stub
		Optional<Doctor> optional = doctorRepository.findById(id);
		return optional;
	}

	@Override
	public Doctor save(DoctorModel model) {
		// TODO Auto-generated method stub
		Doctor doctor = new Doctor();
		doctor.setDoctorId(model.getDoctorId());
		doctor.setUser(model.getUser());
		doctor.setRegistrationNumber(model.getRegistrationNumber());		
		doctor.setCreatedAt(LocalDateTime.now());
		doctor.setCreatedBy(model.getCreatedBy());
		doctor.setUpdatedAt(LocalDateTime.now());
		doctor.setUpdatedBy(model.getUpdatedBy());
		doctor.setIsActive(true);
		
		doctorRepository.save(doctor);
		return doctor;
	}

}
