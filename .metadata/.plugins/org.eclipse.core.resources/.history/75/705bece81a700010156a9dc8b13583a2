package com.tsm.travel.adapters.input.rest;

import java.util.Map;

import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.tsm.travel.application.service.GetBookingServiceImpl;
import com.tsm.travel.application.service.InsertBookingServiceImpl;
import com.tsm.travel.shared.exception.InvalidInputException;
import com.tsm.travel.domain.models.BookingRequestModel;
import com.tsm.travel.domain.models.BookingResponseModel;

@RestController
@RequestMapping("/api/bookings")
public class BookingController {
	private static final Logger logger = LoggerFactory.getLogger(BookingController.class);
    
	
	@Autowired
	private GetBookingServiceImpl getbookingService;
	
	@Autowired
	private InsertBookingServiceImpl insertbookingService;
	
	@GetMapping("{bookingId}")
    public ResponseEntity<BookingResponseModel> getBookingById(@PathVariable int bookingId) {
		logger.info("Received request to fetch booking with ID: {}", bookingId);
    	 if (bookingId <= 0) {
    		 logger.error("Invalid booking ID provided: {}", bookingId);
             throw new InvalidInputException("Invalid ID: ID must be greater than 0.");
         }
    	
         BookingResponseModel bookingResponce = getbookingService.getBookingResponseById(bookingId);
        
         if (bookingResponce == null) {
        	 logger.error("No booking found for ID: {}", bookingId);
             throw new InvalidInputException("Destination with ID " + bookingId + " not found.");
         }
         logger.info("Returning booking details for ID: {}", bookingId);
         return ResponseEntity.ok(bookingResponce);   
         }
	
	@PostMapping()
	public ResponseEntity<?> createNewBooking(@RequestBody BookingRequestModel bookingRequest){
		
		 logger.info("Received booking request: {}", bookingRequest);
			
		 
		 if (bookingRequest == null) {
				 logger.warn("Booking request is null");
				throw new InvalidInputException("Invalid booking data received.");
			}
			//System.out.println("data is comming in controller..");
		 logger.info("data is comming in controller..");
			
		 try {
	            boolean isCreated = insertbookingService.createNewBooking(bookingRequest);

	            if (isCreated) {
	                logger.info("Booking successfully created for userId: {}", bookingRequest.getUserId());
	                return ResponseEntity
	                        .status(HttpStatus.CREATED)
	                        .body(Map.of("message", "Booking created successfully", "status", HttpStatus.CREATED.value()));
	            } else {
	                logger.error("Booking creation failed for userId: {}", bookingRequest.getUserId());
	                throw new InvalidInputException("Booking could not be created. Please try again.");
	            }
	        } catch (Exception e) {
	            logger.error("Exception occurred while creating booking: ", e);
	            throw e;
	        }
	    }
	
	
}
