package com.tsm.invoice.application.service;

import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;

import com.tsm.invoice.domain.exception.InvoiceException;
import com.tsm.invoice.domain.models.DatabaseProcedureRequest;
import com.tsm.invoice.domain.models.InvoiceBillDetails;
import com.tsm.invoice.domain.models.InvoiceBillDetailsRequest;
import com.tsm.invoice.domain.ports.input.GetInvoiceIdUseCase;
import com.tsm.invoice.domain.ports.input.InsertInvoiceUseCase;
import com.tsm.invoice.domain.ports.output.InvoiceRepository;
import com.tsm.invoice.shared.constants.AppConstants;
import com.tsm.invoice.shared.utils.Convertors;
import com.tsm.invoice.shared.utils.InvoiceUtils;
import com.tsm.invoice.shared.utils.ObjectMappers;
import com.tsm.invoice.shared.utils.Validatiors;

/**
 * 
 */
@Service
public class InsertInvoiceServiceImpl implements InsertInvoiceUseCase {

	private InvoiceRepository invoiceRepository;
	private GetInvoiceIdUseCase getInvoiceIdUseCase;
	
	public InsertInvoiceServiceImpl(InvoiceRepository invoiceRepository,GetInvoiceIdUseCase getInvoiceIdUseCase) {
		this.invoiceRepository = invoiceRepository;
		this.getInvoiceIdUseCase = getInvoiceIdUseCase;
	}

	@Override
	public ResponseEntity<?> insertInvoice(InvoiceBillDetailsRequest invoiceBillDetailsRequest) {
		// TODO Auto-generated method stub

		// validate

		 //validateRequestInput(invoiceBillRequest);

		//
		DatabaseProcedureRequest databaseProcedureRequest = getDatabaseProcedureRequest(invoiceBillDetailsRequest);

		invoiceRepository.execute(databaseProcedureRequest);

		return null;
	}

	private ResponseEntity<?> validateRequestInput(InvoiceBillDetailsRequest invoiceBillDetailsRequest) {
		if (Validatiors.isNullOrEmpty(invoiceBillDetailsRequest.getFirstName())) {
			throw new InvoiceException("First Name is mandatory.");
		}

		if (Validatiors.isNullOrEmpty(invoiceBillDetailsRequest.getLastName())) {
			throw new InvoiceException("Last Name is mandatory.");
		}

		return null;

	}

	private DatabaseProcedureRequest getDatabaseProcedureRequest(InvoiceBillDetailsRequest invoiceBillDetailsRequest) {
		
		DatabaseProcedureRequest databaseProcedureRequest = new DatabaseProcedureRequest();
		List<InvoiceBillDetails> list = new ArrayList<InvoiceBillDetails>();
		HashMap<String, Object> inputMap = new HashMap<String, Object>();

		try {
			String procedureName = InvoiceUtils.getProcedureName(AppConstants.ProcedureName.BO_INVOICEBILLDETAILS);
			
			databaseProcedureRequest.setParam_process("INSERT");
			databaseProcedureRequest.setProcedure(procedureName);
			
			InvoiceBillDetails invoiceBillDetails = ObjectMappers.convertDtoToEntity(invoiceBillDetailsRequest);
			String invoiceId = getInvoiceId();
			invoiceBillDetails.setInvoiceId(invoiceId);
			list.add(invoiceBillDetails);
			
			
			inputMap.put("payload", list);

			String payload = Convertors.convertObjectToString(inputMap);

			databaseProcedureRequest.setParam_JSON(payload);
		} catch (Exception e) {
			// TODO: handle exception
		}
		
		return databaseProcedureRequest;
	}
	
	@SuppressWarnings("unchecked")
	private String getInvoiceId() {
		String invoiceId = "";
		ResponseEntity<?> responseEntity = getInvoiceIdUseCase.getInvoiceIdForToDay();
		Object object = responseEntity.getBody(); // {#result-set-1=[], #update-count-1=0}
		Map<String, Object> responseMap = Convertors.convertObjectToMap(object);
		List<Map<String, Object>> listOfMap = (List<Map<String, Object>>) responseMap.get("#result-set-1");
		if(listOfMap.size()==0) {
			invoiceId = InvoiceUtils.generateInvoiceId(0);
			return invoiceId;
		}
		int invId = Convertors.getIntValue(listOfMap.get(0).get("invoiceId"));
		invoiceId = InvoiceUtils.generateInvoiceId(invId);
		return invoiceId;
	}

}
