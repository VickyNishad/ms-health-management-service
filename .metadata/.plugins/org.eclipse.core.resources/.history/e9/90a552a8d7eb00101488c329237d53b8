package com.medicque.adapter.out.persistence;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

import com.medicque.adapter.out.persistence.entity.Doctor;
import com.medicque.adapter.out.persistence.entity.DoctorClinic;
import com.medicque.adapter.out.persistence.jpa.JPADoctorClinicRepository;
import com.medicque.application.port.out.DoctorClinicRepositoryPort;

/**
 * 
 */
@Component
public class DoctorClinicRepositoryAdapter implements DoctorClinicRepositoryPort {
	
	@Autowired
	private JPADoctorClinicRepository doctorClinicRepository;

	@Override
	public DoctorClinic save(DoctorClinic doctorClinic) {
		// TODO Auto-generated method stub
		doctorClinicRepository.save(doctorClinic);
		return doctorClinic;
	}

	@Override
	public List<DoctorClinic> findByDoctor(Doctor doctor) {
		// TODO Auto-generated method stub
		return doctorClinicRepository.findByDoctor(doctor);
	}

}
