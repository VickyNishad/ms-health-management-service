<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true">

    <!-- Read dynamic properties from application.properties -->
    <springProperty scope="context" name="logDir" source="log.dir"/>
    <springProperty scope="context" name="logFileName" source="log.filename"/>

    <!-- Log format -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- Rolling log file path (includes only date) -->
    <property name="LOG_PATH" value="${logDir}/${logFileName}_%d{ddMMyyyy}.log"/>

    <!-- Console output -->
    <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Daily Rolling File Appender -->
    <appender name="RollingFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- ❗ No <file> → active file will also have the date in its name -->
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Specific logger levels -->
    <logger name="com.bittybrain" level="DEBUG"/>
    <logger name="org.springframework" level="WARN"/>

    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="Console"/>
        <appender-ref ref="RollingFile"/>
    </root>

</configuration>
