package com.healthcare.repository;

import java.util.List;

import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.stereotype.Repository;

import com.healthcare.models.entity.AreaMaster;

/**
 * 
 */
@Repository
public interface AreaMasterRepository  extends JpaRepository<AreaMaster, Long>{

	List<AreaMaster> findByCityNameAndIsActiveTrue(String cityName);

	List<AreaMaster> findByAreaNameContainingIgnoreCaseAndIsActiveTrue(String areaName);
}
