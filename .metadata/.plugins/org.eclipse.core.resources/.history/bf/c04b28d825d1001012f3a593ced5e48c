	@Override
	public ResponseEntity<?> insertDoctorProfile(GenericModel<DoctorRegistration> model) {
		// TODO Auto-generated method stub
		ResponseModel responseModel = null;		
		try {
			DoctorRegistration doctorProfile = model.getRequest();
			
			AuthTokenResponse authTokenResponse = model.getAuthTokenResponse();
			
			TValidatiors.validateRequestedField("profileId", authTokenResponse.getProfileId(), true, true, false, false, null, 0, 0, true);
			TValidatiors.validateRequestedField("userId", authTokenResponse.getUserId(), true, true, false, false, null, 0, 0, true);
			TValidatiors.validateRequestedField("fullName",doctorProfile.getFullName() , true, false, false, false, null, 0, 0, true);
			TValidatiors.validateRequestedField("gender",doctorProfile.getGender() , true, false, false, false, null, 0, 0, true);
			TValidatiors.validateRequestedField("age",doctorProfile.getAge(), true, true, false, false, null, 0, 0, true);
			TValidatiors.validateRequestedField("experience",doctorProfile.getTotalYearsOfExperience(), true, true, false, false, null, 0, 0, true);
			TValidatiors.validateRequestedField("emailId",doctorProfile.getEmailId(), true, false, false, false, null, 0, 0, true);
			TValidatiors.validateRequestedField("mobileNumber",doctorProfile.getMobileNumber(), true, true, false, false, null, 0, 0, true);
			TValidatiors.validateRequestedField("qualification",doctorProfile.getQualification(), true, false, false, false, null, 0, 0, true);
			TValidatiors.validateRequestedField("registrationNumber",doctorProfile.getMedicalRegistrationNumber(), true, false, false, false, null, 0, 0, true);
			
			int[] specializations = doctorProfile.getSpecializations();
			if(specializations.length != 0) {
				for(int specialization : specializations) {
					TValidatiors.validateRequestedField("specialization",TUtils.getStringValue(specialization), true, true, false, false, null, 0, 0, true);
				}
			}else {
				TValidatiors.validateRequestedField("specialization",null, true, true, false, false, null, 0, 0, true);
			}
			
			// 
			
			DoctorRegistration doctorRegistration = model.getRequest();

			DoctorProfileDto doctorProfileDto = new DoctorProfileDto();
			doctorProfileDto.setUserId(TUtils.getIntValue(authTokenResponse.getUserId()));
			doctorProfileDto.setProfileId(authTokenResponse.getProfileId());
			doctorProfileDto.setFullName(doctorRegistration.getFullName());
			doctorProfileDto.setAge(doctorRegistration.getAge());
			doctorProfileDto.setEmailId(doctorRegistration.getEmailId());
			doctorProfileDto.setGender(doctorRegistration.getGender());
			doctorProfileDto.setMedicalRegistrationNumber(doctorRegistration.getMedicalRegistrationNumber());
			doctorProfileDto.setMobileNumber(doctorRegistration.getMobileNumber());
			doctorProfileDto.setProfileDescription(doctorRegistration.getProfileDescription());
			doctorProfileDto.setQualification(doctorRegistration.getQualification());
			StringBuilder builder = new StringBuilder();
			int[] specialization = doctorRegistration.getSpecializations();

			String joinedSpecializations = Arrays.stream(specialization)
			                                     .mapToObj(String::valueOf) // convert int -> String
			                                     .collect(Collectors.joining(","));

			builder.append(joinedSpecializations);

			doctorProfileDto.setSpecializations(builder.toString());
			doctorProfileDto.setTotalYearsOfExperience(doctorRegistration.getTotalYearsOfExperience());
		
			DBProcedureRequest dbProcedureRequest = TUtils.getDatabaseRequest(model,doctorProfileDto, TConstants.ParamProcess.INSERT_DOCTOR_PROFILE);

			
			
			Map<String, Object> response = repository.execute(dbProcedureRequest);
			if(TValidatiors.isNullOrEmpty(response) || !response.containsKey(TConstants.ResultSet.RESULT_SET_1)) {
				throw new RuntimeException(TConstants.Error.RESULT_SET_NOT_FOUND);
			}
			String message = "";
			List<Map<String, Object>> lists =  (List<Map<String, Object>>) response.get(TConstants.ResultSet.RESULT_SET_1);
			
			if(TValidatiors.isNullOrEmpty(lists)) {
				throw new DataNotFoundException(TConstants.Error.TECHNICAL_ISSUE);
			}
			
			if(TUtils.getStringValue(lists.get(0).get(TConstants.Keys.RESULT)).equalsIgnoreCase(TConstants.Keys.ERROR)) {
				message = TUtils.getStringValue(lists.get(0).get(TConstants.Keys.MESSAGE));
				throw new RuntimeException(message);
			}
			
			responseModel = new ResponseModel(TConstants.Success.SUCCESS, TUtils.getSuccess(lists.get(0)));
			return new ResponseEntity<>(responseModel,HttpStatus.OK);
		} catch (DataNotFoundException e) {
			throw new DataNotFoundException(e.getMessage());
		} catch (RuntimeException e) {
			throw new TException(e.getMessage());
		} catch (Exception e) {
			throw new TException(TConstants.Error.TECHNICAL_ISSUE);
		}
	}

