	@Override
	public ResponseEntity<?> getTodaysAppointment(GenericModel<String> model) {
		// TODO Auto-generated method stub
		try {
			AuthTokenResponse tokenResponse = model.getAuthTokenResponse();
			TValidatiors.validateRequestedField("profileId", tokenResponse.getProfileId(), true, true, false, false, null, 0, 0, true);
			
			Map<String, Object> request = new HashMap<>();
			request.put("profileId", tokenResponse.getProfileId());
			
			DBProcedureRequest dbProcedureRequest = TUtils.getDatabaseRequest(model,request, TConstants.ParamProcess.GET_TODAYS_ALL_APPOINTMENT);
			
			Map<String, Object> response = repository.execute(dbProcedureRequest);

			ResponseModel responseModel = null;
			List<Map<String, Object>> appointments = new ArrayList<>();
			List<Map<String, Object>> lists =  (List<Map<String, Object>>) response.get(TConstants.ResultSet.RESULT_SET_1);
			
			if(TValidatiors.isNullOrEmpty(response) || !response.containsKey(TConstants.ResultSet.RESULT_SET_1)) {
				responseModel = new ResponseModel(TConstants.Success.SUCCESS, TUtils.getSuccess(lists));
			}
			if(TValidatiors.isNullOrEmpty(lists)) {
				responseModel = new ResponseModel(TConstants.Success.SUCCESS, TUtils.getSuccess(lists));
			}
			boolean firstBookedFound = false;
			lists.sort(Comparator.comparingInt(item -> Integer.parseInt(item.get("tokenNumber").toString())));
			
			for (Map<String, Object> appointment : lists) {
				String s2 = TUtils.getStringValue(appointment.get("status"));
				if (!firstBookedFound && s2.equalsIgnoreCase("Booked")) {
					appointments.add(getAction(appointment, true));
					firstBookedFound = true;
				} else {
					appointments.add(getAction(appointment, false));
				}
			}

			responseModel = new ResponseModel(TConstants.Success.SUCCESS, TUtils.getSuccess(appointments));
			return new ResponseEntity<>(responseModel,HttpStatus.OK);
		} catch (DataNotFoundException e) {
			throw new DataNotFoundException(e.getMessage());
		} catch (RuntimeException e) {
			throw new TException(e.getMessage());
		} catch (Exception e) {
			throw new TException(TConstants.Error.TECHNICAL_ISSUE);
		}
	}
	
	private Map<String, Object> getAction(Map<String, Object> res,boolean isEnable){
		Map<String, Object> action = new HashMap<>();
		action.put("isEnable", isEnable);
		res.put("action", action);
		return res;
	}

