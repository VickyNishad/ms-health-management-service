	public static AuthTokenResponse getHeaders(HttpServletRequest request) {
		AuthTokenResponse authTokenResponse = new AuthTokenResponse();
		Map<String, Object> info = null;

		if (TValidatiors.isNullOrEmpty(request)) {
			return authTokenResponse;
		}

		List<String> headers = Arrays.asList("authorization");

		for (String header : headers) {
			String value = request.getHeader(header);
			info = getTokenDetails(value);
		}

		if (TValidatiors.isNullOrEmpty(info)) {
			return authTokenResponse;
		}
		
		
		if (!info.containsKey("data")) {
			return authTokenResponse;
		}

		authTokenResponse = TConvertors.convertObjectToPojo(info.get("data"),
				AuthTokenResponse.class);

		return authTokenResponse;
	}

