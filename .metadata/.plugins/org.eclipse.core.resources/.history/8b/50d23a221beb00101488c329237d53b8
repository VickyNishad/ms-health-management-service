	public static Map<String, Object> getTokenDetails(String auth) {

		Map<String, Object> tokenMap = new HashMap<String, Object>();
		if(TValidatiors.isNullOrEmpty(auth)) {
			return tokenMap;
		}
		String token = auth.replace("Bearer ", "");

		String[] parts = token.split("\\.");

		if (parts.length != 3) {
			return tokenMap;
		}

		String payloadJson = new String(Base64.getUrlDecoder().decode(parts[1]));

		tokenMap = TConvertors.convertStringToMap(payloadJson);

		return tokenMap;
	}
	
	
	public static String getGoogleIdFromFederatedId(String federatedId) {
	    if (federatedId == null || federatedId.isEmpty()) {
	        return null;
	    }
	    int lastSlashIndex = federatedId.lastIndexOf('/');
	    if (lastSlashIndex != -1 && lastSlashIndex < federatedId.length() - 1) {
	        return federatedId.substring(lastSlashIndex + 1);
	    }
	    return null;
	}
	
	
	
    /**
     * Returns the next or same LocalDate for the given day string.
     * Accepts "MONDAY", "monday", "Mon", "mon", "1".."7" (ISO: MONDAY=1 .. SUNDAY=7).
     * Falls back to scanning next 7 days if parsing fails.
     */
    public static LocalDate getNextOrSameFor(String dayStr) {
        if (dayStr == null || dayStr.isBlank()) {
            throw new IllegalArgumentException("dayStr is null/blank");
        }

        dayStr = dayStr.trim();

        // 1) Try numeric (1..7) — ISO standard: MONDAY=1 ... SUNDAY=7
        if (dayStr.matches("\\d+")) {
            int v = Integer.parseInt(dayStr);
            if (v >= 1 && v <= 7) {
                DayOfWeek target = DayOfWeek.of(v);
                return LocalDate.now().with(TemporalAdjusters.nextOrSame(target));
            }
        }

        // 2) Try exact enum names (MONDAY, TUESDAY, ...)
        try {
            DayOfWeek target = DayOfWeek.valueOf(dayStr.toUpperCase(Locale.ROOT));
            return LocalDate.now().with(TemporalAdjusters.nextOrSame(target));
        } catch (IllegalArgumentException ignored) {
            // continue to try other formats
        }

        // 3) Try three-letter abbreviations like "Mon", "Tue"
        String up3 = dayStr.length() >= 3 ? dayStr.substring(0, 3).toUpperCase(Locale.ROOT) : dayStr.toUpperCase(Locale.ROOT);
        for (DayOfWeek d : DayOfWeek.values()) {
            if (d.name().substring(0, 3).equals(up3)) {
                return LocalDate.now().with(TemporalAdjusters.nextOrSame(d));
            }
        }

        // 4) As a final fallback, scan the next 7 days and return the first match (robust)
        LocalDate today = LocalDate.now();
        for (int i = 0; i < 7; i++) {
            LocalDate candidate = today.plusDays(i);
            if (candidate.getDayOfWeek().name().equalsIgnoreCase(dayStr) ||
                candidate.getDayOfWeek().name().startsWith(up3)) {
                return candidate;
            }
        }

        // If nothing matched
        throw new IllegalArgumentException("Could not parse day: '" + dayStr + "'");
    }
	
