package com.auth.service;

import java.nio.charset.StandardCharsets;
import java.util.Date;

import javax.crypto.SecretKey;

import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;

import com.auth.constant.TConstants;
import com.auth.exception.AuthenticationFailedException;
import com.auth.interfaces.TAbstractUseCase;
import com.auth.interfaces.usecase.AuthRefereshTokenUseCase;
import com.auth.models.GenericModel;
import com.auth.models.request.DBProcedureRequest;
import com.auth.models.response.AuthTokenResponse;
import com.auth.models.response.ResponseModel;
import com.auth.utils.TUtils;

import io.jsonwebtoken.Claims;
import io.jsonwebtoken.ExpiredJwtException;
import io.jsonwebtoken.Jwts;
import io.jsonwebtoken.SignatureAlgorithm;
import io.jsonwebtoken.security.Keys;

/**
 * 
 */
@Service
public class AuthRefereshTokenServiceImpl extends TAbstractUseCase<String, DBProcedureRequest, ResponseEntity<?>> implements AuthRefereshTokenUseCase {

	private final String SECRET_KEY = "my-very-secure-secret-key-1234567890";  // 🔐 Use env var in real apps
	private final long ACCESS_TOKEN_VALIDITY_MS = 5 * 60 * 1000; // 5 minutes
	private final SecretKey secretKey = Keys.hmacShaKeyFor(SECRET_KEY.getBytes(StandardCharsets.UTF_8));

	@Override
	protected ResponseEntity<?> validateInput(GenericModel<String> model) {
		// TODO Auto-generated method stub
		return new ResponseEntity<>(HttpStatus.OK);
	}

	@Override
	protected DBProcedureRequest buildDatabaseRequest(GenericModel<String> model) {
		// TODO Auto-generated method stub
		DBProcedureRequest dbProcedureRequest = new DBProcedureRequest();
		return dbProcedureRequest;
	}

	@Override
	protected ResponseEntity<?> execute(GenericModel<String> model, DBProcedureRequest dbRequest) {
		// TODO Auto-generated method stub
		return new ResponseEntity<>(HttpStatus.OK);
	}

	@Override
	protected ResponseEntity<?> buildFinalResponse(GenericModel<String> model, ResponseEntity<?> result) {
		// TODO Auto-generated method stub
		
		long now = System.currentTimeMillis();
        Date accessExpiry = new Date(now + ACCESS_TOKEN_VALIDITY_MS); 

        try {
            // Validate refresh token
            Claims claims = Jwts.parserBuilder()
                    .setSigningKey(secretKey)
                    .build()
                    .parseClaimsJws(model.getRequest())
                    .getBody();

            // Extract subject (user info)
            String subject = claims.getSubject();

            String newAccessToken = Jwts.builder()
                    .setSubject(subject)
                    .setIssuer("auth-service")
                    .setIssuedAt(new Date(now))
                    .setExpiration(accessExpiry)
                    .signWith(secretKey, SignatureAlgorithm.HS256)
                    .compact();

            AuthTokenResponse tokenResponse = new AuthTokenResponse();
            tokenResponse.setAccessToken(newAccessToken);
            tokenResponse.setAccessTokenExpiresAt(TUtils.getStringValue(accessExpiry));
            tokenResponse.setRefereshToken(model.getRequest()); // (optional) reuse or rotate
            tokenResponse.setRefreshTokenExpiresAt(TUtils.getStringValue(claims.getExpiration()));

            ResponseModel responseModel = new ResponseModel();
            responseModel.setStatus(TConstants.Keys.SUCCESS);
            responseModel.setData(TUtils.getSuccess(tokenResponse));

            return new ResponseEntity<>(responseModel, HttpStatus.OK);
        } catch (ExpiredJwtException e) {
        	throw new AuthenticationFailedException("Refresh token expired");
        } catch (Exception e) {
        	throw new AuthenticationFailedException("Invalid refresh token");
        }
	}

	

}
