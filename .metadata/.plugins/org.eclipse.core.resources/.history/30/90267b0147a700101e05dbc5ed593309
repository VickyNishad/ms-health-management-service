@Service
public class GetTodaysAppointmentServiceImpl extends TAbstractUseCase<String, DBProcedureRequest, Map<String, Object>> implements GetTodaysAppointmentUseCase {

	
	private TRepository tRepository;

	public GetTodaysAppointmentServiceImpl(TRepository tRepository) {
		this.tRepository = tRepository;
	}
	@Override
	protected ResponseEntity<?> validateInput(GenericModel<String> model) {
		// TODO Auto-generated method stub
		AuthTokenResponse tokenResponse = model.getAuthTokenResponse();
//		TValidatiors.validateRequestedField("profileId", tokenResponse.getProfileId(), true, true, false, false, null, 0, 0, true);

		return new  ResponseEntity<>(HttpStatus.OK);
	}

	@Override
	protected DBProcedureRequest buildDatabaseRequest(GenericModel<String> model) {
		// TODO Auto-generated method stub
		AuthTokenResponse tokenResponse = model.getAuthTokenResponse();

		Map<String, Object> request = new HashMap<>();
		request.put("profileId", 6);//tokenResponse.getProfileId());
		
		DBProcedureRequest dbProcedureRequest = TUtils.getDatabaseRequest(model,request, TConstants.ParamProcess.GET_TODAYS_ALL_APPOINTMENT);
		return dbProcedureRequest;
	}

	@Override
	protected Map<String, Object> execute(GenericModel<String> model, DBProcedureRequest dbRequest) {
		// TODO Auto-generated method stub
		try {
			Map<String, Object> response = tRepository.execute(dbRequest);
			
			return response;
		} catch (DatabaseException e) {
			throw new DatabaseException(e.getMessage());
		} catch (RuntimeException e) {
			throw new DataNotFoundException(e.getMessage());
		} catch (Exception e) {
			throw new TException(TConstants.Error.TECHNICAL_ISSUE);
		}
		
	}

	@Override
	protected ResponseEntity<?> buildFinalResponse(GenericModel<String> model,
			Map<String, Object> result) {
		// TODO Auto-generated method stub
		try {
			ResponseModel responseModel = null;
			Map<String, Object> res = new HashMap<String, Object>();
			List<Map<String, Object>> appointments = new ArrayList<>();
			List<Map<String, Object>> lists =  (List<Map<String, Object>>) result.get(TConstants.ResultSet.RESULT_SET_1);
			
			if(TValidatiors.isNullOrEmpty(result) || !result.containsKey(TConstants.ResultSet.RESULT_SET_1)) {
				responseModel = new ResponseModel(TConstants.Success.SUCCESS, TUtils.getSuccess(lists));
			}
			if(TValidatiors.isNullOrEmpty(lists)) {
				responseModel = new ResponseModel(TConstants.Success.SUCCESS, TUtils.getSuccess(lists));
			}
			
			lists.sort(Comparator.comparingInt(item -> 
		    Integer.parseInt(item.get("tokenNumber").toString())));
			if(lists.size()==1) {
				
			}else {
				for(int i=1; i<lists.size(); i++) {
					String s1 = TUtils.getStringValue(lists.get(i-1).get("status"));
					String s2 = TUtils.getStringValue(lists.get(i).get("status"));
					if(s2.equalsIgnoreCase("Booked")) {
						if(!s1.equalsIgnoreCase("Booked")) {
							appointments.add(lists.get(i));
							System.out.println("true:------");
						}else {
							appointments.add(lists.get(i));
							System.out.println("false:------");
						}
					}
				}
			}

			responseModel = new ResponseModel(TConstants.Success.SUCCESS, TUtils.getSuccess(lists));
			return new ResponseEntity<>(responseModel,HttpStatus.OK);
		} catch (DataNotFoundException e) {
			throw new DataNotFoundException(e.getMessage());
		} catch (RuntimeException e) {
			throw new TException(e.getMessage());
		} catch (Exception e) {
			throw new TException(TConstants.Error.TECHNICAL_ISSUE);
		}
	}
	
	private Map<String, Object> getAction(Map<String, Object> res,boolean isEnable){
		Map<String, Object> action = new HashMap<>();
		action.put("isEnable", isEnable);
		res.put("action", action);
		return res;
	}

}
