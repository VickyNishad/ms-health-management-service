package com.health.repository.impl;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

import com.health.model.DoctorQualification;
import com.health.repository.DoctorQualificationRepositoryService;
import com.health.repository.jpa.JPADoctorQualificationRepository;



/**
 * 
 */
@Component
public class DoctorQualificationRepositoryImpl implements DoctorQualificationRepositoryService {
	
	@Autowired
	private JPADoctorQualificationRepository doctorQualificationRepository;

	@Override
	public DoctorQualification save(DoctorQualification doctorQualification) {
		// TODO Auto-generated method stub
		doctorQualificationRepository.save(doctorQualification);
		return doctorQualification;
	}

}
