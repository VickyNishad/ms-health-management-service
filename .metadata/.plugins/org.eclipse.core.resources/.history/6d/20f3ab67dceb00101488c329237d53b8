package com.health.application.service;

import java.util.List;
import java.util.Map;
import java.util.stream.Collectors;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;

import com.common.models.ApiResponse;
import com.common.utility.ApiExecutionUtils;
import com.health.adapter.in.rest.dto.MenuConfig;
import com.health.config.MenuConfigLoader;

@Service
public class MenuService {

    @Autowired
    private final MenuConfigLoader loader = new MenuConfigLoader();

    public ResponseEntity<ApiResponse<Map<String, Object>>> loadMenu(String role) {

        ApiResponse<Map<String, Object>> success = ApiExecutionUtils.ApiExecutor.processRequest(
            null,
            req -> {},
            () -> {
                MenuConfig config = loader.getConfig();

                // get permissions for this role
                List<String> permissions = config.getRoleDefaultPermissions()
                        .getOrDefault(role, List.of());

                // filter menus by role + permission
                List<Map<String, Object>> menus = config.getAllMenus().stream()
                        .filter(menu -> menu.getAllowedRoles().contains(role))
                        .filter(menu -> permissions.contains(menu.getPermissionKey()))
                        .map(menu -> Map.of(
                                "key", menu.getKey(),                   // keep original key
                                "title", menu.getTitle(),
                                "baseRoute", "/"+role+menu.getBaseRoute(),     // keep baseRoute
                                "permissionKey", menu.getPermissionKey(),
                                "icon", menu.getIcon(),
                                "allowedRoles", menu.getAllowedRoles()
                        ))
                        .collect(Collectors.toList());

                return Map.of(
                        "allMenus", menus,
                        "roleDefaultPermissions", config.getRoleDefaultPermissions()
                );
            },
            ApiResponse::success
        );

        return new ResponseEntity<ApiResponse<Map<String, Object>>>(success, HttpStatus.OK);
    }
}
