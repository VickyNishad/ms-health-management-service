package com.medicque.domain.model;

import com.medicque.adapter.out.persistence.entity.RoleMaster;

/**
 * 
 */
public class UserRegistrationModel {

	private Long userId;
	private String fullName;

	private String emailId;

	private String contactNumber;

	private String providerLoginId;

	private String password;

	private RoleMaster role;

	private String socialId;

	private String profilePicture;

	private String loginType;

	public UserRegistrationModel() {
		super();
		// TODO Auto-generated constructor stub
	}

	public UserRegistrationModel(String fullName, String emailId, String contactNumber, String providerLoginId,
			String password, RoleMaster role, String socialId, String profilePicture, String loginType) {
		super();
		this.fullName = fullName;
		this.emailId = emailId;
		this.contactNumber = contactNumber;
		this.providerLoginId = providerLoginId;
		this.password = password;
		this.role = role;
		this.socialId = socialId;
		this.profilePicture = profilePicture;
		this.loginType = loginType;
	}

	public Long getUserId() {
		return userId;
	}

	public void setUserId(Long userId) {
		this.userId = userId;
	}

	public String getFullName() {
		return fullName;
	}

	public void setFullName(String fullName) {
		this.fullName = fullName;
	}

	public String getEmailId() {
		return emailId;
	}

	public void setEmailId(String emailId) {
		this.emailId = emailId;
	}

	public String getContactNumber() {
		return contactNumber;
	}

	public void setContactNumber(String contactNumber) {
		this.contactNumber = contactNumber;
	}

	public String getProviderLoginId() {
		return providerLoginId;
	}

	public void setProviderLoginId(String providerLoginId) {
		this.providerLoginId = providerLoginId;
	}

	public String getPassword() {
		return password;
	}

	public void setPassword(String password) {
		this.password = password;
	}

	public RoleMaster getRole() {
		return role;
	}

	public void setRole(RoleMaster role) {
		this.role = role;
	}

	public String getSocialId() {
		return socialId;
	}

	public void setSocialId(String socialId) {
		this.socialId = socialId;
	}

	public String getProfilePicture() {
		return profilePicture;
	}

	public void setProfilePicture(String profilePicture) {
		this.profilePicture = profilePicture;
	}

	public String getLoginType() {
		return loginType;
	}

	public void setLoginType(String loginType) {
		this.loginType = loginType;
	}

}
