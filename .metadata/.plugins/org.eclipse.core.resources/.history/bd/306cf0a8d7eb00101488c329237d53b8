package com.medicque.adapter.out.persistence;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

import com.health.adapter.out.persistence.entity.QualificationMaster;
import com.health.adapter.out.persistence.jpa.JPAQualificationMasterRepository;
import com.health.application.port.out.QualificationMasterRepositoryPort;

/**
 * 
 */
@Component
public class QualificationMasterRepositoryAdpter implements QualificationMasterRepositoryPort {
	
	@Autowired
	private JPAQualificationMasterRepository qualificationMasterRepository;

	@Override
	public List<QualificationMaster> findAllById(List<Long> id) {
		// TODO Auto-generated method stub
		return qualificationMasterRepository.findAllById(id);
	}

}
