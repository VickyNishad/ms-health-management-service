	@Override
	public ResponseEntity<ApiResponse<MessageResponse>> updateLeaveOrBreak(Long leaveId, DoctorLeaveRequest doctorLeaveRequest) {
		// TODO Auto-generated method stub		
		ApiResponse<DoctorLeave> leave = ApiExecutionUtils.ApiExecutor.processRequest(doctorLeaveRequest, req -> {
		}, () -> {
			DoctorLeave existing = doctorLeaveRepositoryPort.findById(leaveId)
					.orElseThrow(() -> new RuntimeException("Leave not found."));
