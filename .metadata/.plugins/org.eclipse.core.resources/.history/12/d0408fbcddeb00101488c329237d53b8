	@Override
	@Transactional(rollbackFor = Exception.class)
	public ResponseEntity<ApiResponse<MessageResponse>> saveProfile(DoctorProfileRequest doctorProfileRequest) {
		// TODO Auto-generated method stub

		// Step 1: Get UserRegistration
		ApiResponse<MessageResponse> success = ApiExecutionUtils.ApiExecutor.processRequest(doctorProfileRequest,
				req -> {
				}, () -> {
					Optional<UserRegistration> user = useRepositoryPort.findById(doctorProfileRequest.getUserId());
					if (!user.isPresent()) {
						// return message
						throw new RuntimeException("User not found. Please create an account to proceed.");
					}

					// Step 2: Save Doctor
					DoctorModel doctorModel = new DoctorModel();
					doctorModel.setDoctorId(null);
					doctorModel.setExperienceYears(doctorProfileRequest.getExperienceYears());
					doctorModel.setRegistrationNumber(doctorProfileRequest.getRegistrationNumber());
					doctorModel.setUpdatedBy(null);
					doctorModel.setCreatedBy(null);
					doctorModel.setUser(user.get());

					Doctor doctor = doctorRepositoryPort.save(doctorModel);

					if (doctorProfileRequest.getSpecializtionsId() != null) {
						List<SpecializationMaster> specs = specializationMasterRepositoryPort
								.findAllById(doctorProfileRequest.getSpecializtionsId());
						for (SpecializationMaster s : specs) {
							DoctorSpecialization ds = new DoctorSpecialization();
							ds.setDoctor(doctor);
							ds.setSpecialization(s);
							ds.setCreatedBy(null);
							ds.setIsActive(true);
							doctorSpecializationRepositoryPort.save(ds);
						}
					}

					// Step 5: Save DoctorQualifications
					if (doctorProfileRequest.getQualificationsId() != null) {
						List<QualificationMaster> quals = qualificationMasterRepositoryPort
								.findAllById(doctorProfileRequest.getQualificationsId());
						for (QualificationMaster q : quals) {
							DoctorQualification dq = new DoctorQualification();
							dq.setDoctor(doctor);
							dq.setQualification(q);
							dq.setCreatedBy(null);
							dq.setIsActive(true);
							doctorQualificationRepositoryPort.save(dq);
						}
					}

					// Step 6: Handle Clinics

					for (ClinicRequest clinicReq : doctorProfileRequest.getClinics()) {

						Clinic clinic = new Clinic();
						clinic.setClinicName(clinicReq.getClinicName());
						clinic.setAddress(clinicReq.getAddress());
						clinic.setContactNumber(clinicReq.getContactNumber());
						clinic.setCreatedBy(null);
						clinic.setIsActive(true);
						clinicRepositoryPort.save(clinic);

						// Create DoctorClinic mapping
						DoctorClinic mapping = new DoctorClinic();
						mapping.setDoctor(doctor);
						mapping.setClinic(clinic);
						mapping.setCreatedBy(null);
						mapping.setIsActive(true);
						doctorClinicRepositoryPort.save(mapping);

					}
					return new MessageResponse("Doctor onboarded successfully.");
				}, ApiResponse::success);
		return new ResponseEntity<ApiResponse<MessageResponse>>(success, HttpStatus.OK);
	}

	@Override
	public ResponseEntity<ApiResponse<DoctorProfileResponse>> getProfile(Long doctorId) {

		ApiResponse<DoctorProfileResponse> success = ApiExecutionUtils.ApiExecutor.processRequest(doctorId, req -> {
		}, () -> {
			Optional<Doctor> optional = doctorRepositoryPort.findById(doctorId);
			if(optional==null || optional.isEmpty()) {
				throw new RuntimeException("Doctor not found.");
			}
			Doctor doctor = optional.get();
			DoctorProfileResponse response = new DoctorProfileResponse();
			response.setDoctorId(doctor.getDoctorId());
			response.setFullName(doctor.getUser().getFullName());
			response.setRegistrationNumber(doctor.getRegistrationNumber());
			response.setExperienceYears(doctor.getExperienceYears());

			// Specializations
			response.setSpecializations(doctor.getSpecializations().stream()
					.map(SpecializationMaster::getSpecializationName).collect(Collectors.toList()));

			// Qualifications
			response.setQualifications(doctor.getQualifications().stream()
					.map(QualificationMaster::getQualificationName).collect(Collectors.toList()));

			// Clinics
			List<ClinicResponse> clinics = doctorClinicRepositoryPort.findByDoctor(doctor).stream().map(dc -> {
				Clinic c = dc.getClinic();
				ClinicResponse cr = new ClinicResponse();
				cr.setClinicId(c.getClinicId());
				cr.setClinicName(c.getClinicName());
				cr.setAddress(c.getAddress());
				cr.setContactNumber(c.getContactNumber());
				return cr;
			}).collect(Collectors.toList());
			response.setClinics(clinics);

			return response;
		}, ApiResponse::success);
		return new ResponseEntity<ApiResponse<DoctorProfileResponse>>(success, HttpStatus.OK);
	}

