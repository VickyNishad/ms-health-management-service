package com.document.controller;

import org.springframework.http.MediaType;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.ModelAttribute;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RequestPart;
import org.springframework.web.bind.annotation.RestController;
import org.springframework.web.multipart.MultipartFile;

import com.document.interfaces.usecase.TestUseCase;
import com.document.models.GenericModel;
import com.document.models.request.DocumentRequest;
import com.document.models.request.IsRegisterUserRequest;

/**
 * 
 */
@RestController
@RequestMapping
public class DocumentController {
	private TestUseCase testUseCase;
	public DocumentController(TestUseCase testUseCase) {
		this.testUseCase = testUseCase;
	}

	@PostMapping("/send")
	public String getString(@RequestBody IsRegisterUserRequest isRegisterUserRequest) {
		GenericModel<IsRegisterUserRequest> gen = new GenericModel<IsRegisterUserRequest>();
		gen.setPayload(isRegisterUserRequest);
		testUseCase.handle(gen);
		return  "";
	}
	

	  @PostMapping(value = "/upload", consumes = "multipart/form-data")
	    public ResponseEntity<String> uploadDocument(@ModelAttribute DocumentRequest documentRequest) {
	        MultipartFile file = documentRequest.getMultipartFile();

	        // Validate & process the file and metadata
	        System.out.println("File Name: " + documentRequest.getFileName());
	        System.out.println("Reference ID: " + documentRequest.getReferenceId());
	        System.out.println("Uploaded File: " + file.getOriginalFilename());

	        // ... Upload to S3, call DB, etc.

	        return ResponseEntity.ok("File uploaded successfully.");
	    }
	
}
