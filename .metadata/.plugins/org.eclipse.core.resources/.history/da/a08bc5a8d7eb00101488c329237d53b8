package com.medicque.adapter.in.rest.dto;

import java.util.List;

public class DoctorAvailabilityUpdateRequest {
	private String dayOfWeek;
	private Long clinicId;
	private List<DoctorAvailabilityRequest> availabilityList; // list of time ranges

	public String getDayOfWeek() {
		return dayOfWeek;
	}

	public void setDayOfWeek(String dayOfWeek) {
		this.dayOfWeek = dayOfWeek;
	}

	public Long getClinicId() {
		return clinicId;
	}

	public void setClinicId(Long clinicId) {
		this.clinicId = clinicId;
	}

	public List<DoctorAvailabilityRequest> getAvailabilityList() {
		return availabilityList;
	}

	public void setAvailabilityList(List<DoctorAvailabilityRequest> availabilityList) {
		this.availabilityList = availabilityList;
	}

}
