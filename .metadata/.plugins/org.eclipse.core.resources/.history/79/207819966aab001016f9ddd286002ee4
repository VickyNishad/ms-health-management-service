package com.healthcare.service;

import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;

import com.healthcare.constant.TConstants;
import com.healthcare.exception.DataNotFoundException;
import com.healthcare.exception.DatabaseException;
import com.healthcare.exception.TException;
import com.healthcare.interfaces.TAbstractUseCase;
import com.healthcare.interfaces.TRepository;
import com.healthcare.interfaces.usecase.GetDoctorDetailsUseCase;
import com.healthcare.models.GenericModel;
import com.healthcare.models.request.DBProcedureRequest;
import com.healthcare.models.response.AuthTokenResponse;
import com.healthcare.models.response.ResponseModel;
import com.healthcare.utils.TUtils;
import com.healthcare.utils.TValidatiors;

/**
 * 
 */
@Service
public class GetDoctorDetailsServiceImpl extends TAbstractUseCase<String, DBProcedureRequest, Map<String, Object>> implements GetDoctorDetailsUseCase {

	
	private TRepository tRepository;

	public GetDoctorDetailsServiceImpl(TRepository tRepository) {
		this.tRepository = tRepository;

	}
	@Override
	protected ResponseEntity<?> validateInput(GenericModel<String> model) {
		// TODO Auto-generated method stub	 
		AuthTokenResponse authTokenResponse = model.getAuthTokenResponse();
		TValidatiors.validateRequestedField("doctorId",authTokenResponse.getProfileId(), true, false, false, false, null, 0, 0, true);
		return new ResponseEntity<>(HttpStatus.OK);
	}

	@Override
	protected DBProcedureRequest buildDatabaseRequest(GenericModel<String> model) {
		// TODO Auto-generated method stub
		AuthTokenResponse authTokenResponse = model.getAuthTokenResponse();

		Map<String, Object> request = new HashMap<String, Object>();
		request.put("profileId", authTokenResponse.getProfileId());
		DBProcedureRequest dbProcedureRequest = TUtils.getDatabaseRequest(model,request, TConstants.ParamProcess.GET_DOCTOR_PROFILE);

		return dbProcedureRequest;
	}

	@Override
	protected Map<String, Object> execute(GenericModel<String> model, DBProcedureRequest dbRequest) {
		// TODO Auto-generated method stub
		try {
			Map<String, Object> response = tRepository.execute(dbRequest);
			if(TValidatiors.isNullOrEmpty(response) || !response.containsKey(TConstants.ResultSet.RESULT_SET_1)) {
				throw new RuntimeException(TConstants.Error.RESULT_SET_NOT_FOUND);
			}
			return response;
		} catch (DatabaseException e) {
			throw new DatabaseException(e.getMessage());
		} catch (RuntimeException e) {
			throw new DataNotFoundException(e.getMessage());
		} catch (Exception e) {
			throw new TException(TConstants.Error.TECHNICAL_ISSUE);
		}
	}

	@Override
	protected ResponseEntity<?> buildFinalResponse(GenericModel<String> model, Map<String, Object> result) {
		// TODO Auto-generated method stub
		// TODO Auto-generated method stub
		try {
			ResponseModel responseModel = null;
			Map<String, Object> response = new HashMap<String, Object>();
			List<Map<String, Object>> listOfdoctor = new ArrayList<Map<String,Object>>();
			List<Map<String, Object>> listOfAddress = new ArrayList<Map<String,Object>>();
			String message = "";
			List<Map<String, Object>> doctors = (List<Map<String, Object>>) result.get(TConstants.ResultSet.RESULT_SET_1);
			List<Map<String, Object>> addresss = (List<Map<String, Object>>) result.get(TConstants.ResultSet.RESULT_SET_2);

			if (TValidatiors.isNullOrEmpty(doctors) || TValidatiors.isNullOrEmpty(addresss)) {
				throw new DataNotFoundException(TConstants.Error.RESULT_SET_NOT_FOUND);
			}
			if (TUtils.getStringValue(doctors.get(0).get(TConstants.Keys.RESULT)).equalsIgnoreCase(TConstants.Keys.ERROR)) {
				message = TUtils.getStringValue(doctors.get(0).get(TConstants.Keys.MESSAGE));
				throw new RuntimeException(message);
			}
			for(Map<String, Object> doctor : doctors) {
				response = new HashMap<String, Object>();
				response.putAll(doctor);
				listOfAddress = new ArrayList<Map<String,Object>>();
				for(Map<String, Object> address : addresss) {
					if(TUtils.getStringValue(doctor.get("profileId")).equalsIgnoreCase(TUtils.getStringValue(address.get("profileId")))) {	
						if(TUtils.getStringValue(address.get("isUploaded")).equalsIgnoreCase("1")) {
							address.put("isUploaded", true);
						}else {
							address.put("isUploaded", false);
						}
						listOfAddress.add(address);					
					}		
				}	
				response.put("address", listOfAddress);
				listOfdoctor.add(response);
			}
			responseModel = new ResponseModel(TConstants.Success.SUCCESS, TUtils.getSuccess(listOfdoctor));
			return new ResponseEntity<>(responseModel, HttpStatus.OK);
		} catch (DataNotFoundException e) {
			throw new DataNotFoundException(e.getMessage());
		} catch (RuntimeException e) {
			throw new TException(e.getMessage());
		} catch (Exception e) {
			throw new TException(TConstants.Error.TECHNICAL_ISSUE);
		}
	}

}
