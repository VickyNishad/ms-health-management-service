	}
	
	
	private LocalTime toTime(String t) {
	    return (t == null || t.isEmpty()) ? null : LocalTime.parse(t);
	}

	
	
	private void validateAvailability(
	        LocalTime mStart, LocalTime mEnd,
	        LocalTime aStart, LocalTime aEnd,
	        LocalTime eStart, LocalTime eEnd
	) {
	    if (mStart != null && mEnd != null && mEnd.isBefore(mStart)) {
	        throw new RuntimeException("Morning end time cannot be before start time");
	    }
	    if (aStart != null && aEnd != null && aEnd.isBefore(aStart)) {
	        throw new RuntimeException("Afternoon end time cannot be before start time");
	    }
	    if (eStart != null && eEnd != null && eEnd.isBefore(eStart)) {
	        throw new RuntimeException("Evening end time cannot be before start time");
	    }

	    // Overlap checks
	    checkOverlap(mStart, mEnd, aStart, aEnd);
	    checkOverlap(mStart, mEnd, eStart, eEnd);
	    checkOverlap(aStart, aEnd, eStart, eEnd);
	}

	private void checkOverlap(LocalTime s1, LocalTime e1, LocalTime s2, LocalTime e2) {
	    if (s1 == null || e1 == null || s2 == null || e2 == null) return;

	    if (!e1.isBefore(s2) && !e2.isBefore(s1)) {
	        throw new RuntimeException("Time ranges cannot overlap");
	    }
	}

