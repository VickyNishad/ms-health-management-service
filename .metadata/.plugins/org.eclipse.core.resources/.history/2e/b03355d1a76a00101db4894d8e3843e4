package com.tsm.invoice.shared.utils;

import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.Map;

import com.tsm.invoice.shared.constants.AppConstants;

/**
 * 
 */
public class InvoiceUtils {
	
	 public static String generateInvoiceId(int latestInvoiceNumber) {
		 // Get current date in YYYYMMDD format
	     String currentDate = new SimpleDateFormat("yyyyMMdd").format(new Date()); 
		 if (latestInvoiceNumber==0) {
		        // If no invoices for today, start with 001
		        return "INV-" + currentDate + "-001";
		 }
	             
	     // Generate invoice number (e.g., INV-20250726-001)
		 // Ensure 3-digit format (001, 002, ...)
	        String invoiceNumber = String.format("%03d", latestInvoiceNumber + 1);
	        return "INV-" + currentDate + "-" + invoiceNumber;
	    }
	
	public static void removeKeyFromMap(Map<String, Object> map,String key) {
		map.remove(key);
		System.out.println("Successfully remove "+key+" from map");
	}

	public static String getProcedureName(String key) {
		String procedureName = "";
		try {
			switch (key) {
			case AppConstants.ProcedureName.USP_MANAGEBILLING:
				procedureName = key;
				break;
				
			case AppConstants.ProcedureName.GETLATESTINVOICEIDFORTODAY:
				procedureName = key;
			break;
			case AppConstants.ProcedureName.BO_INVOICEBILLDETAILS:
				procedureName = key;
			break;
			
			default:
				break;
			}
			if(procedureName.isEmpty()) {
				throw new Exception("Unknown proedure Name : "+key);
			}
		} catch (Exception e) {
			// TODO: handle exception
		}
		return procedureName; 
	}
}
