	@SuppressWarnings("unchecked")
	@Override
	public ResponseEntity<?> bookAppointment(GenericModel<AppointmentRequest> model) {
		// TODO Auto-generated method stub
		ResponseModel responseModel = null;
		String message = "";
		String familyMemberId = "";
		try {
			AppointmentRequest appointmentRequest = model.getRequest();

			AuthTokenResponse authTokenResponse = model.getAuthTokenResponse();
			TValidatiors.validateRequestedField("profileId", authTokenResponse.getProfileId(), true, false, false,
					false, null, 0, 0, true);
			TValidatiors.validateRequestedField("slotId", TUtils.getStringValue(appointmentRequest.getSlotId()), true,
					false, false, false, null, 0, 0, true);
			TValidatiors.validateRequestedField("fullName", appointmentRequest.getFullName(), true, false, false,
					false, null, 0, 0, true);
			TValidatiors.validateRequestedField("mobileNumber", appointmentRequest.getMobileNumber(), true, false, false,
					false, null, 0, 0, true);
			
			if (TValidatiors.isNullOrEmpty(appointmentRequest.getFamilyMemberId())) {

				appointmentRequest.setProfileId(TUtils.getIntValue(authTokenResponse.getProfileId()));
				Map<String, Object> request = TConvertors.convertObjectToMap(appointmentRequest);

				DBProcedureRequest dbProcedureRequest = TUtils.getDatabaseRequest(model, request, "ADDFAMILYMEMBER");
				/**
				 * 
				 */
				Map<String, Object> req = TConvertors.convertObjectToMap(dbProcedureRequest);
				Map<String, Object> response = tRepository.execute(req, "ADDFAMILYMEMBER", "USP_ManageAppointment");
				List<Map<String, Object>> lists = (List<Map<String, Object>>) response
						.get(TConstants.ResultSet.RESULT_SET_1);
				if (lists.size() > 0) {
					if (lists.get(0).containsKey("error")) {
						throw new RuntimeException(TUtils.getStringValue(lists.get(0).get("message")));
					}
				} else {
					throw new RuntimeException(TConstants.Error.TECHNICAL_ISSUE);
				}

				familyMemberId = TUtils.getStringValue(TUtils.getStringValue(lists.get(0).get("familyMemberId")));

			} else {

				appointmentRequest.setProfileId(TUtils.getIntValue(authTokenResponse.getProfileId()));
				Map<String, Object> request = TConvertors.convertObjectToMap(appointmentRequest);

				DBProcedureRequest dbProcedureRequest = TUtils.getDatabaseRequest(model, request, "UPDATEFAMILYMEMBER");
				/**
				 * 
				 */
				Map<String, Object> req = TConvertors.convertObjectToMap(dbProcedureRequest);
				Map<String, Object> response = tRepository.execute(req, "UPDATEFAMILYMEMBER", "USP_ManageAppointment");

				List<Map<String, Object>> lists = (List<Map<String, Object>>) response
						.get(TConstants.ResultSet.RESULT_SET_1);
				if (lists.size() > 0) {
					if (lists.get(0).containsKey("error")) {
						throw new RuntimeException(TUtils.getStringValue(lists.get(0).get("message")));
					}
				} else {
					throw new RuntimeException(TConstants.Error.TECHNICAL_ISSUE);
				}

				familyMemberId = TUtils.getStringValue(TUtils.getStringValue(lists.get(0).get("familyMemberId")));
			}

			appointmentRequest.setFamilyMemberId(familyMemberId);
			appointmentRequest.setProfileId(TUtils.getIntValue(authTokenResponse.getProfileId()));
			DBProcedureRequest dbProcedureRequest = TUtils.getDatabaseRequest(model, appointmentRequest,
					TConstants.ParamProcess.APPOINTMENT_BOOK);

			Map<String, Object> response = tRepository.execute(dbProcedureRequest);
			if (TValidatiors.isNullOrEmpty(response) || !response.containsKey(TConstants.ResultSet.RESULT_SET_1)) {
				throw new RuntimeException(TConstants.Error.RESULT_SET_NOT_FOUND);
			}

			List<Map<String, Object>> lists = (List<Map<String, Object>>) response
					.get(TConstants.ResultSet.RESULT_SET_1);
			if (TValidatiors.isNullOrEmpty(lists)) {
				throw new DataNotFoundException(TConstants.Error.RESULT_SET_NOT_FOUND);
			}
			if (TUtils.getStringValue(lists.get(0).get(TConstants.Keys.RESULT))
					.equalsIgnoreCase(TConstants.Keys.ERROR)) {
				message = TUtils.getStringValue(lists.get(0).get(TConstants.Keys.MESSAGE));
				throw new RuntimeException(message);
			}
			StringBuilder builder = new StringBuilder();
			builder.append("Your appointment with ").append(TUtils.getStringValue(lists.get(0).get("doctorName")))
					.append(" is confirmed");

			int appointmentId = TUtils.getIntValue(lists.get(0).get("appointmentId"));

			try {
				NotificationRequest notificationRequest = new NotificationRequest();
				notificationRequest.setDeliveryChannels("APP");
				notificationRequest.setIsRead(false);
				notificationRequest.setMessage(builder.toString());
				notificationRequest.setNotificationType(NotificationType.BOOKING);
				notificationRequest.setEntityId(appointmentId);
				notificationRequest.setTitle("Booking Confirmed");
				notificationRequest.setUserProfileId(TUtils.getIntValue(authTokenResponse.getProfileId()));

				GenericModel<NotificationRequest> noGenericModel = new GenericModel<NotificationRequest>();
				noGenericModel.setAuthTokenResponse(authTokenResponse);
				noGenericModel.setRequest(notificationRequest);

				ResponseEntity<?> responseEntity = insertNotificationUseCase.handle(noGenericModel);
				System.out.println("Notification : " + responseEntity.getBody());

			} catch (Exception e) {
				System.out.println("Exception : " + e.getLocalizedMessage());
			}

			pushNotificationAsync.appointmentBookedNotification(appointmentId);

			responseModel = new ResponseModel(TConstants.Success.SUCCESS, TUtils.getSuccess(lists.get(0)));
			return new ResponseEntity<>(responseModel, HttpStatus.OK);
		} catch (DataNotFoundException e) {
			throw new DataNotFoundException(e.getMessage());
		} catch (RuntimeException e) {
			throw new TException(e.getMessage());
		} catch (Exception e) {
			throw new TException(TConstants.Error.TECHNICAL_ISSUE);
		}
	}

	@Override
	public ResponseEntity<?> modifyAppointment(GenericModel<UpdateAppointmentRequest> model) {
		// TODO Auto-generated method stub
		ResponseModel responseModel = null;
		String message = "";
		try {
			UpdateAppointmentRequest appointmentRequest = model.getRequest();
			AppointmentStatus status = appointmentRequest.getNewStatus();
			AuthTokenResponse authTokenResponse = model.getAuthTokenResponse();

			if (TValidatiors.isNullOrEmpty(status)) {
				throw new InvalidInputException("newStatus" + TConstants.Error.CANNOT_BE_NULL_OR_EMPTY);
			}

			TValidatiors.validateRequestedField("appointmentId", appointmentRequest.getAppointmentId(), true, false,
					false, false, null, 0, 0, true);
			TValidatiors.validateRequestedField("profileId", authTokenResponse.getProfileId(), true, false, false,
					false, null, 0, 0, true);

			String paramProcess = TConstants.ParamProcess.APPOINTMENT_BOOK;
			switch (status.name()) {
			case "SCHEDULED":
				paramProcess = TConstants.ParamProcess.APPOINTMENT_UPDATE;
				break;
			case "CONFIRMED":
				paramProcess = TConstants.ParamProcess.APPOINTMENT_UPDATE;
				break;
			case "RESCHEDULED":
				paramProcess = TConstants.ParamProcess.APPOINTMENT_UPDATE;
				break;
			case "CANCELLED":
				paramProcess = TConstants.ParamProcess.APPOINTMENT_UPDATE;
				break;
			case "COMPLETED":
				paramProcess = TConstants.ParamProcess.APPOINTMENT_UPDATE;
				break;
			case "NOSHOW":
				paramProcess = TConstants.ParamProcess.APPOINTMENT_UPDATE;
				break;
			case "PENDING":
				paramProcess = TConstants.ParamProcess.APPOINTMENT_UPDATE;
				break;
			case "CLOSED":
				paramProcess = TConstants.ParamProcess.APPOINTMENT_UPDATE;
				break;
			default:
				break;
			}

			appointmentRequest.setExecutedByProfileId(TUtils.getIntValue(authTokenResponse.getProfileId()));
			DBProcedureRequest dbProcedureRequest = TUtils.getDatabaseRequest(model, paramProcess);

			Map<String, Object> response = tRepository.execute(dbProcedureRequest);
			if (TValidatiors.isNullOrEmpty(response) || !response.containsKey(TConstants.ResultSet.RESULT_SET_1)) {
				throw new RuntimeException(TConstants.Error.RESULT_SET_NOT_FOUND);
			}

			@SuppressWarnings("unchecked")
			List<Map<String, Object>> lists = (List<Map<String, Object>>) response
					.get(TConstants.ResultSet.RESULT_SET_1);
			if (TValidatiors.isNullOrEmpty(lists)) {
				throw new DataNotFoundException(TConstants.Error.RESULT_SET_NOT_FOUND);
			}
			if (TUtils.getStringValue(lists.get(0).get(TConstants.Keys.RESULT))
					.equalsIgnoreCase(TConstants.Keys.ERROR)) {
				message = TUtils.getStringValue(lists.get(0).get(TConstants.Keys.MESSAGE));
				throw new RuntimeException(message);
			}

			message = TUtils.getStringValue(lists.get(0).get(TConstants.Keys.MESSAGE));
			responseModel = new ResponseModel(TConstants.Success.SUCCESS, TUtils.getSuccess(lists.get(0)));

			return new ResponseEntity<>(responseModel, HttpStatus.OK);

		} catch (DataNotFoundException e) {
			throw new DataNotFoundException(e.getMessage());
		} catch (RuntimeException e) {
			throw new TException(e.getMessage());
		} catch (Exception e) {
			throw new TException(TConstants.Error.TECHNICAL_ISSUE);
		}
	}

	@SuppressWarnings("unchecked")
	@Override
	public ResponseEntity<?> getAppointment(GenericModel<MyAppointmentRequest> model) {
		// TODO Auto-generated method stub
		ResponseModel responseModel = null;
		try {
			MyAppointmentRequest myAppointmentRequest = model.getRequest();

			TValidatiors.validateRequestedField("profileId", TUtils.getStringValue(myAppointmentRequest.getProfileId()),
					true, false, false, false, null, 0, 0, true);

			AuthTokenResponse authTokenResponse = model.getAuthTokenResponse();

			myAppointmentRequest.setRole(authTokenResponse.getRole());
			if (TValidatiors.isNullOrEmpty(myAppointmentRequest.getLimit())) {
				myAppointmentRequest.setLimit(1);
			}

			myAppointmentRequest.setProfileId(TUtils.getIntValue(authTokenResponse.getProfileId()));

			DBProcedureRequest dbProcedureRequest = TUtils.getDatabaseRequest(model, myAppointmentRequest,
					TConstants.ParamProcess.GET_MY_APPOINTMENTS);

			Map<String, Object> response = tRepository.execute(dbProcedureRequest);
			if (TValidatiors.isNullOrEmpty(response)) {
				throw new RuntimeException(TConstants.Error.TECHNICAL_ISSUE);
			}

			List<Map<String, Object>> lists = (List<Map<String, Object>>) response
					.get(TConstants.ResultSet.RESULT_SET_1);

			responseModel = new ResponseModel(TConstants.Success.SUCCESS, TUtils.getSuccess(lists));
			return new ResponseEntity<>(responseModel, HttpStatus.OK);
		} catch (DataNotFoundException e) {
			throw new DataNotFoundException(e.getMessage());
		} catch (RuntimeException e) {
			throw new TException(e.getMessage());
		} catch (Exception e) {
			throw new TException(TConstants.Error.TECHNICAL_ISSUE);
		}
	}

