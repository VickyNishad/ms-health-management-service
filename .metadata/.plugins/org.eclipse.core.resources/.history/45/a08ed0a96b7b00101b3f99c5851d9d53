package com.document.controller;

import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.document.interfaces.usecase.TestUseCase;
import com.document.models.GenericModel;
import com.document.models.request.IsRegisterUserRequest;

/**
 * 
 */
@RestController
@RequestMapping
public class DocumentController {
	private TestUseCase testUseCase;
	public DocumentController(TestUseCase testUseCase) {
		this.testUseCase = testUseCase;
	}

	@PostMapping("send")
	public String getString(@RequestBody IsRegisterUserRequest isRegisterUserRequest) {
		GenericModel<IsRegisterUserRequest> gen = new GenericModel<IsRegisterUserRequest>();
		gen.setPayload(isRegisterUserRequest);
		testUseCase.handle(gen);
		return  "";
	}
}
