package com.healthcare.controller;

import org.springdoc.core.annotations.ParameterObject;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.CrossOrigin;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.healthcare.interfaces.ManageAdminUseCase;
import com.healthcare.interfaces.ManageStaffUseCase;
import com.healthcare.interfaces.usecase.KycUpdateUseCase;
import com.healthcare.models.request.AuthLoginRequest;
import com.healthcare.models.request.FilterRequest;
import com.healthcare.models.request.KycUpdateRequest;
import com.healthcare.models.request.StaffRequest;
import com.healthcare.models.request.UpdateStaffByCreatorRequest;
import com.healthcare.utils.TUtils;

import jakarta.servlet.http.HttpServletRequest;

/**
 * 
 */
@CrossOrigin(origins = "*", allowedHeaders = "*")
@RestController
@RequestMapping(AuthController.BASE_URL+AdminController.BASE_URL)
public class AdminController {
	public static final String BASE_URL = "/admin";

	private KycUpdateUseCase kycUpdateUseCase;
	private ManageAdminUseCase manageAdminUseCase;
	private ManageStaffUseCase manageStaffUseCase;

	public AdminController(KycUpdateUseCase kycUpdateUseCase, ManageAdminUseCase manageAdminUseCase,
			ManageStaffUseCase manageStaffUseCase) {
		this.kycUpdateUseCase = kycUpdateUseCase;
		this.manageAdminUseCase = manageAdminUseCase;
		this.manageStaffUseCase = manageStaffUseCase;
	}

	@PostMapping("/update-kyc-status")
	public ResponseEntity<?> updateKycStatus(@RequestBody KycUpdateRequest kycUpdateRequest, HttpServletRequest request) {
	    return kycUpdateUseCase.handle(TUtils.getObjectFromRequest(kycUpdateRequest, request));
	}
	
	
	@GetMapping("/get-pending-doctors")
	public ResponseEntity<?> getPendingDoctorOrClinics(@ParameterObject FilterRequest filterRequest ,HttpServletRequest request) {
	    return manageAdminUseCase.getPendingDoctorOrClinics(TUtils.getObjectFromRequest(filterRequest, request));
	}
	
	
	@PostMapping("/add-staff")
	public ResponseEntity<?> add(@RequestBody StaffRequest authLoginRequest, HttpServletRequest request) {
	    return manageStaffUseCase.addSatff(TUtils.getObjectFromRequest(authLoginRequest, request));
	}
	@PostMapping("/update-staff")
	public ResponseEntity<?> updateStaff(@RequestBody UpdateStaffByCreatorRequest staffRequest, HttpServletRequest request) {
	    return manageStaffUseCase.updateSatffByCreator(TUtils.getObjectFromRequest(staffRequest, request));
	}
	@GetMapping("/get-staff")
	public ResponseEntity<?> getSatff(HttpServletRequest request) {
	    return manageStaffUseCase.getSatff(TUtils.getObjectFromRequest("", request));
	}
	
	
}
