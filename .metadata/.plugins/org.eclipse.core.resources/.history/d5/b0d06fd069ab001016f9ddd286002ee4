package com.healthcare.service;

import java.util.HashMap;
import java.util.List;
import java.util.Map;

import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;

import com.healthcare.constant.TConstants;
import com.healthcare.exception.DataNotFoundException;
import com.healthcare.exception.DatabaseException;
import com.healthcare.exception.TException;
import com.healthcare.interfaces.TAbstractUseCase;
import com.healthcare.interfaces.TRepository;
import com.healthcare.interfaces.usecase.GetAddressDetailsUseCase;
import com.healthcare.models.GenericModel;
import com.healthcare.models.request.DBProcedureRequest;
import com.healthcare.models.response.AuthTokenResponse;
import com.healthcare.models.response.ResponseModel;
import com.healthcare.utils.TUtils;
import com.healthcare.utils.TValidatiors;

/**
 * 
 */
@Service
public class GetAddressDetailsServiceImpl extends TAbstractUseCase<String, DBProcedureRequest, Map<String, Object>> implements GetAddressDetailsUseCase {

	private TRepository tRepository;

	public GetAddressDetailsServiceImpl(TRepository tRepository) {
		this.tRepository = tRepository;
	}
	@Override
	protected ResponseEntity<?> validateInput(GenericModel<String> model) {
		// TODO Auto-generated method stub
		AuthTokenResponse authTokenResponse = model.getAuthTokenResponse();
		TValidatiors.validateRequestedField("profileId",authTokenResponse.getProfileId(), true, false, false, false, null, 0, 0, true);
		return new  ResponseEntity<>(HttpStatus.OK);
	}

	@Override
	protected DBProcedureRequest buildDatabaseRequest(GenericModel<String> model) {
		// TODO Auto-generated method stub
		AuthTokenResponse authTokenResponse = model.getAuthTokenResponse();
		
		DBProcedureRequest dbProcedureRequest = TUtils.getDatabaseRequest(model,authTokenResponse, TConstants.ParamProcess.GET_ADDRESS_DETAILS);
		return dbProcedureRequest;
	}

	@Override
	protected Map<String, Object> execute(GenericModel<String> model, DBProcedureRequest dbRequest) {
		// TODO Auto-generated method stub
		try {
			Map<String, Object> response = tRepository.execute(dbRequest);
			if(TValidatiors.isNullOrEmpty(response) || !response.containsKey(TConstants.ResultSet.RESULT_SET_1)) {
				throw new RuntimeException(TConstants.Error.RESULT_SET_NOT_FOUND);
			}
			List<Map<String, Object>> lists =  (List<Map<String, Object>>) response.get(TConstants.ResultSet.RESULT_SET_1);
			if(TValidatiors.isNullOrEmpty(lists)) {
				throw new DataNotFoundException(TConstants.Error.RESULT_SET_NOT_FOUND);
			}
			
			return response;
		} catch (DatabaseException e) {
			throw new DatabaseException(e.getMessage());
		} catch (RuntimeException e) {
			throw new DataNotFoundException(e.getMessage());
		} catch (Exception e) {
			throw new TException(TConstants.Error.TECHNICAL_ISSUE);
		}
		
	}

	@Override
	protected ResponseEntity<?> buildFinalResponse(GenericModel<String> model,Map<String, Object> result) {
		// TODO Auto-generated method stub
		try {
			ResponseModel responseModel = null;

			List<Map<String, Object>> lists =  (List<Map<String, Object>>) result.get(TConstants.ResultSet.RESULT_SET_1);
			
			responseModel = new ResponseModel(TConstants.Success.SUCCESS, TUtils.getSuccess(lists));
			return new ResponseEntity<>(responseModel,HttpStatus.OK);
		} catch (DataNotFoundException e) {
			throw new DataNotFoundException(e.getMessage());
		} catch (RuntimeException e) {
			throw new TException(e.getMessage());
		} catch (Exception e) {
			throw new TException(TConstants.Error.TECHNICAL_ISSUE);
		}
	}

}

