package com.healthcare.models.entity;

import jakarta.persistence.Column;
import jakarta.persistence.Entity;
import jakarta.persistence.GeneratedValue;
import jakarta.persistence.GenerationType;
import jakarta.persistence.Id;
import jakarta.persistence.Table;
import jakarta.persistence.UniqueConstraint;

/**
 * 
 */

@Entity
@Table(name = "Area_Master", uniqueConstraints = { @UniqueConstraint(columnNames = { "area_name", "city_name" }) })

public class AreaMaster {

	@Id
	@GeneratedValue(strategy = GenerationType.IDENTITY)
	@Column(name = "area_id")
	private Long areaId;

	@Column(name = "area_name", nullable = false, length = 150)
	private String areaName;

	@Column(name = "city_name", nullable = false, length = 150)
	private String cityName;

	@Column(name = "pincode", length = 10)
	private String pincode;

	@Column(name = "is_active", nullable = false)
	private Boolean isActive = true;
}
