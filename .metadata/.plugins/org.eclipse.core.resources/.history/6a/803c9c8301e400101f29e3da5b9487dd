package com.healthcare.repository;

import java.util.List;

import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;

import com.healthcare.models.entity.AreaMaster;

/**
 * 
 */
@Repository
public interface AreaMasterRepository  extends JpaRepository<AreaMaster, Long>{
	
    @Query("SELECT DISTINCT a.cityName FROM AreaMaster a WHERE a.isActive = true ORDER BY a.cityName")
    List<String> findAllActiveCities();
    
    
    
    @Query("""
    	    SELECT a FROM AreaMaster a
    	    WHERE a.isActive = true
    	    AND a.pincode LIKE CONCAT(:pincode, '%')
    	    ORDER BY a.cityName, a.areaName
    	""")
    	List<AreaMaster> s(@Param("pincode") String pincode);


	List<AreaMaster> findByCityNameAndIsActiveTrue(String cityName);

	List<AreaMaster> findByAreaNameContainingIgnoreCaseAndIsActiveTrue(String areaName);
}
