package com.health.repository.impl;

import java.time.LocalDate;
import java.util.List;
import java.util.Optional;
import java.util.stream.Collectors;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;


import com.health.domain.model.DoctorLeaveModel;
import com.health.model.DoctorLeave;
import com.health.repository.DoctorLeaveRepositoryPort;
import com.health.repository.jpa.JPADoctorLeaveRepository;

/**
 * 
 */
@Component
public class DoctorLeaveRepositoryImpl implements DoctorLeaveRepositoryPort {

	@Autowired
	public JPADoctorLeaveRepository jpaDoctorLeaveRepository;

	@Override
	public DoctorLeaveModel save(DoctorLeaveModel model) {
		// TODO Auto-generated method stub
		DoctorLeave leave = new DoctorLeave();
		leave.setLeave_id(model.getLeave_id());
		leave.setLeaveType(model.getLeaveType());
		leave.setStartDate(model.getStartDate());
		leave.setEndDate(model.getEndDate());
		leave.setStartTime(model.getStartTime());
		leave.setEndTime(model.getEndTime());
		leave.setLeaveType(model.getLeaveType());
		leave.setReason(model.getReason());
		leave.setDoctor(model.getDoctor_id());
		leave.setCreatedAt(model.getCreatedAt());
		leave.setCreatedBy(model.getCreatedBy());
		leave.setUpdatedAt(model.getUpdatedAt());
		leave.setUpdatedAt(model.getUpdatedAt());
		leave.setIsActive(model.getIsActive());
		
		jpaDoctorLeaveRepository.save(leave);
		
		return model;
	}

	@Override
	public Optional<DoctorLeave> findById(Long id) {
		// TODO Auto-generated method stub
		Optional<DoctorLeave> optional = jpaDoctorLeaveRepository.findById(id);
		return optional;
	}

	@Override
	public List<DoctorLeave> findOverlappingLeaves(Long doctorId, LocalDate startDate, LocalDate endDate) {
		// TODO Auto-generated method stub
		return jpaDoctorLeaveRepository.findOverlappingLeaves(doctorId, startDate, endDate);
	}

	@Override
	public List<DoctorLeave> getDoctorLeaves(Long doctorId) {
		// TODO Auto-generated method stub
		List<DoctorLeave> leaves = jpaDoctorLeaveRepository.findAll()
                .stream()
                .filter(l -> l.getDoctor().getDoctorId().equals(doctorId))
                .collect(Collectors.toList());
		return leaves;
	}

	@Override
	public List<DoctorLeave> findByDoctorAndDate(Long doctorId, LocalDate date) {
		// TODO Auto-generated method stub
		return jpaDoctorLeaveRepository.findByDoctorAndDate(doctorId, date);
	}

}
