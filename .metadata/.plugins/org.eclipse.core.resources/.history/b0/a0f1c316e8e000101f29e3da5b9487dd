package com.medicque.application.service;

import java.time.LocalDateTime;
import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;

import com.common.models.ApiResponse;
import com.common.utility.ApiExecutionUtils;
import com.medicque.adapter.in.rest.dto.FamilyMemberRequest;
import com.medicque.adapter.in.rest.dto.MessageResponse;
import com.medicque.adapter.out.persistence.entity.FamilyMember;
import com.medicque.adapter.out.persistence.entity.UserRegistration;
import com.medicque.adapter.out.persistence.jpa.JPAFamilyMemberRepository;
import com.medicque.application.port.in.FamilyMemberUseCase;
import com.medicque.application.port.out.UserRegistrationRepositoryPort;

/**
 * 
 */
@Service
public class FamilyMemberService implements FamilyMemberUseCase {
	
	@Autowired
	private JPAFamilyMemberRepository japFamilyMemberRepository;
		
	@Autowired
	private UserRegistrationRepositoryPort useRepositoryPort;

	@Override
	public ResponseEntity<ApiResponse<FamilyMember>> addFamilyMember(Long userId ,FamilyMemberRequest faimilyMemberRequest) {
		// TODO Auto-generated method stub
		ApiResponse<FamilyMember> success = ApiExecutionUtils.ApiExecutor.processRequest(null, req -> {
		}, () -> {
			FamilyMember familyMember = new FamilyMember();

			// 2. Validate Patient
			UserRegistration user = useRepositoryPort.findById(userId)
					.orElseThrow(() -> new RuntimeException("User not found"));
			familyMember.setUser(user);
			familyMember.setFullName(faimilyMemberRequest.getName());
			familyMember.setAge(faimilyMemberRequest.getAge());
			familyMember.setGender(faimilyMemberRequest.getGender());
			familyMember.setIsActive(true);
			familyMember.setRelationship(faimilyMemberRequest.getRelationship());
			familyMember.setContactNumber(faimilyMemberRequest.getContactNumber());
			familyMember.setUpdatedAt(LocalDateTime.now());
			familyMember.setUpdatedBy(userId.toString());

			FamilyMember member = japFamilyMemberRepository.save(familyMember);
			return member;
		}, ApiResponse::success);
		
		return new ResponseEntity<ApiResponse<FamilyMember>>(success, HttpStatus.OK);
	}

	@Override
	public ResponseEntity<ApiResponse<List<FamilyMember>>> getFamilyMember(Long userId) {
		// TODO Auto-generated method stub
		ApiResponse<List<FamilyMember>> success = ApiExecutionUtils.ApiExecutor.processRequest(null, req -> {
		}, () -> {
			List<FamilyMember> familyMembers = japFamilyMemberRepository.findByUser_UserIdAndIsActive(userId, true);
			return familyMembers;
		}, ApiResponse::success);
		return new ResponseEntity<ApiResponse<List<FamilyMember>>>(success, HttpStatus.OK);
	}

	@Override
	public ResponseEntity<ApiResponse<FamilyMember>> modifyFamilyMember(Long userId, Long faimilyMemebrId,FamilyMemberRequest faimilyMemberRequest) {
		// TODO Auto-generated method stub
		ApiResponse<FamilyMember> success = ApiExecutionUtils.ApiExecutor.processRequest(null, req -> {
		}, () -> {
			FamilyMember familyMember = new FamilyMember();

			// 2. Validate Patient
			UserRegistration user = useRepositoryPort.findById(userId)
					.orElseThrow(() -> new RuntimeException("User not found"));

			familyMember.setFamilyMemberId(faimilyMemebrId);
			familyMember.setUser(user);
			familyMember.setFullName(faimilyMemberRequest.getName());
			familyMember.setAge(faimilyMemberRequest.getAge());
			familyMember.setGender(faimilyMemberRequest.getGender());
			familyMember.setIsActive(true);
			familyMember.setRelationship(faimilyMemberRequest.getRelationship());
			familyMember.setContactNumber(faimilyMemberRequest.getContactNumber());
			familyMember.setUpdatedAt(LocalDateTime.now());
			familyMember.setUpdatedBy(userId.toString());

			FamilyMember member = japFamilyMemberRepository.save(familyMember);
			return member;
		}, ApiResponse::success);
		return new ResponseEntity<ApiResponse<FamilyMember>>(success, HttpStatus.OK);
	}

	@Override
	public ResponseEntity<ApiResponse<MessageResponse>> removeFamilyMember(Long userId, Long faimilyMemebrId) {
		// TODO Auto-generated method stub
		// 2. Validate Patient
		
		ApiResponse<MessageResponse> success = ApiExecutionUtils.ApiExecutor.processRequest(null, req->{}, ()->{
			UserRegistration user = useRepositoryPort.findById(userId)
					.orElseThrow(() -> new RuntimeException("User not found"));
			japFamilyMemberRepository.deleteById(faimilyMemebrId);
			return new MessageResponse("");
		}, ApiResponse::success);
		
		return new ResponseEntity<ApiResponse<MessageResponse>>(success, HttpStatus.OK);
	}

	
}
