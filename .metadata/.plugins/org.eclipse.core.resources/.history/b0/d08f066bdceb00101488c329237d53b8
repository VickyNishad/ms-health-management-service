package com.health.adapter.out.persistence;

import java.time.LocalDateTime;
import java.util.Optional;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

import com.health.adapter.out.persistence.entity.UserRegistration;
import com.health.adapter.out.persistence.jpa.JPAUserRegistrationRepository;
import com.health.application.port.out.UserRegistrationRepositoryPort;
import com.health.domain.model.UserRegistrationModel;

/**
 * 
 */
@Component
public class UserRegistrationRepositoryAdapter implements UserRegistrationRepositoryPort {

	@Autowired
	private JPAUserRegistrationRepository userRepository;


	@Override
	public Optional<UserRegistration> findByProviderLoginId(String providerLoginId) {
		// TODO Auto-generated method stub
		Optional<UserRegistration> user = userRepository.findByProviderLoginId(providerLoginId);
		return user;
	}

	@Override
	public UserRegistration save(UserRegistrationModel model) {
		// TODO Auto-generated method stub
	     
	    // create user 
	    UserRegistration userRegistration = new UserRegistration();
	    userRegistration.setUserId(model.getUserId());
	    userRegistration.setEmailId(model.getEmailId());
	    userRegistration.setFullName(model.getFullName());
	    userRegistration.setLoginType(model.getLoginType());
	    userRegistration.setPassword(model.getPassword());
	    userRegistration.setProviderLoginId(model.getProviderLoginId());
	    userRegistration.setRole(model.getRole());
	    userRegistration.setSocialId(model.getSocialId());
	    
	    userRegistration.setCreatedAt(LocalDateTime.now());
	    userRegistration.setCreatedBy(null);
	    userRegistration.setUpdatedAt(LocalDateTime.now());
	    userRegistration.setUpdatedBy(null);
	    userRegistration.setIsActive(true);
	    
	    
	    userRepository.save(userRegistration);
		return userRegistration;
	}

	@Override
	public Optional<UserRegistration> findById(Long id) {
		// TODO Auto-generated method stub
		Optional<UserRegistration> user = userRepository.findById(id);
		return user;
	}

}
