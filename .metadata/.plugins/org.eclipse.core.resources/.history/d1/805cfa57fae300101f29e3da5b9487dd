package com.healthcare.service;

import java.util.ArrayList;
import java.util.Arrays;
import java.util.HashSet;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;
import java.util.Set;

import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;

import com.healthcare.constant.TConstants;
import com.healthcare.exception.DataNotFoundException;
import com.healthcare.exception.DatabaseException;
import com.healthcare.exception.TException;
import com.healthcare.interfaces.TAbstractUseCase;
import com.healthcare.interfaces.TRepository;
import com.healthcare.interfaces.usecase.SearchDoctorUseCase;
import com.healthcare.models.GenericModel;
import com.healthcare.models.request.DBProcedureRequest;
import com.healthcare.models.request.SearchQueryRequest;
import com.healthcare.models.response.ResponseModel;
import com.healthcare.utils.TUtils;
import com.healthcare.utils.TValidatiors;

/**
 * 
 */
@Service
public class SearchDoctorServiceImpl extends TAbstractUseCase<SearchQueryRequest, DBProcedureRequest, Map<String, Object>> implements SearchDoctorUseCase {

	
	private TRepository tRepository;

	public SearchDoctorServiceImpl(TRepository tRepository) {
		this.tRepository = tRepository;

	}
	@Override
	protected ResponseEntity<?> validateInput(GenericModel<SearchQueryRequest> model) {
		// TODO Auto-generated method stub	 
		return new ResponseEntity<>(HttpStatus.OK);
	}

	@Override
	protected DBProcedureRequest buildDatabaseRequest(GenericModel<SearchQueryRequest> model) {
		// TODO Auto-generated method stub
		DBProcedureRequest dbProcedureRequest = TUtils.getDatabaseRequest(model, TConstants.ParamProcess.AUTOSUGGESTION);

		return dbProcedureRequest;
	}

	@Override
	protected Map<String, Object> execute(GenericModel<SearchQueryRequest> model, DBProcedureRequest dbRequest) {
		// TODO Auto-generated method stub
		try {
			Map<String, Object> response = tRepository.execute(dbRequest);
			if(TValidatiors.isNullOrEmpty(response) || !response.containsKey(TConstants.ResultSet.RESULT_SET_1)) {
				throw new RuntimeException(TConstants.Error.RESULT_SET_NOT_FOUND);
			}
			return response;
		} catch (DatabaseException e) {
			throw new DatabaseException(e.getMessage());
		} catch (RuntimeException e) {
			throw new DataNotFoundException(e.getMessage());
		} catch (Exception e) {
			throw new TException(TConstants.Error.TECHNICAL_ISSUE);
		}
	}

	@Override
	protected ResponseEntity<?> buildFinalResponse(GenericModel<SearchQueryRequest> model, Map<String, Object> result) {
		// TODO Auto-generated method stub
		
		try {

			SearchQueryRequest qr = model.getRequest();
			String q = TUtils.getStringValue(qr.getQ()); // Extract query safely
			ResponseModel responseModel;

			List<Map<String, Object>> doctors = (List<Map<String, Object>>) result
					.get(TConstants.ResultSet.RESULT_SET_1);

			// If query is null or empty, return all doctors
			if (q == null || q.trim().isEmpty()) {
				responseModel = new ResponseModel(TConstants.Success.SUCCESS, TUtils.getSuccess(doctors));
				return new ResponseEntity<>(responseModel, HttpStatus.OK);
			}

			// Normalize query: lowercase, remove punctuation, trim
			q = q.toLowerCase().replaceAll("[^a-z0-9 ]", "").trim();
			String[] tokens = q.split("\\s+"); // Split query into tokens (words)

			List<Map<String, Object>> scoredList = new ArrayList<>();

			for (Map<String, Object> item : doctors) {
				LinkedHashMap<String, Object> doctor = new LinkedHashMap<>(item);
				int score = 0;

				// Normalize searchable fields
				String cleanFullName = TUtils.getStringValue(doctor.get("cleanFullName")).toLowerCase();
				String fullName = TUtils.getStringValue(doctor.get("fullName")).toLowerCase();
				String specialization = TUtils.getStringValue(doctor.get("specializations")).toLowerCase();
				String hospitalName = TUtils.getStringValue(doctor.get("hospitalName")).toLowerCase();
				String clinicName = TUtils.getStringValue(doctor.get("clinicName")).toLowerCase();
				String profileDesc = TUtils.getStringValue(doctor.get("profileDescription")).toLowerCase();
				String address = TUtils.getStringValue(doctor.get("address")).toLowerCase();

				// --- Partial exact word matching for cleanFullName (max 5 points) ---
				String[] cleanNameWords = cleanFullName.split("\\s+");
				Set<String> cleanNameSet = new HashSet<>(Arrays.asList(cleanNameWords));
				int cleanMatchCount = 0;
				for (String qw : tokens) {
					if (cleanNameSet.contains(qw))
						cleanMatchCount++;
				}
				int cleanScore = (int) Math.round(((double) cleanMatchCount / tokens.length) * 5);
				score += cleanScore;

				// --- Partial exact word matching for fullName (max 3 points) ---
				String[] fullNameWords = fullName.split("\\s+");
				Set<String> fullNameSet = new HashSet<>(Arrays.asList(fullNameWords));
				int fullMatchCount = 0;
				for (String qw : tokens) {
					if (fullNameSet.contains(qw))
						fullMatchCount++;
				}
				int fullNameScore = (int) Math.round(((double) fullMatchCount / tokens.length) * 3);
				score += fullNameScore;

				// --- Token-based partial match for all tokens across searchable fields (3
				// points) ---
				boolean allTokensMatch = true;
				for (String token : tokens) {
					if (!(cleanFullName.contains(token) || fullName.contains(token) || specialization.contains(token)
							|| hospitalName.contains(token) || clinicName.contains(token) || profileDesc.contains(token)
							|| address.contains(token))) {
						allTokensMatch = false;
						break;
					}
				}
				if (allTokensMatch)
					score += 3;

				// --- Additional partial matches on fields for relevance ---
				if (specialization.contains(q))
					score += 2;
				if (hospitalName.contains(q))
					score += 2;
				if (clinicName.contains(q))
					score += 1;
				if (profileDesc.contains(q))
					score += 1;
				if (address.contains(q))
					score += 1;

				doctor.put("relevanceScore", score);
				scoredList.add(doctor);
			}

			// Sort descending by relevanceScore
			scoredList.sort((a, b) -> Integer.compare((int) b.get("relevanceScore"), (int) a.get("relevanceScore")));

			// Remove relevanceScore before returning
			for (Map<String, Object> d : scoredList) {
				d.remove("relevanceScore");
			}

			responseModel = new ResponseModel(TConstants.Success.SUCCESS, TUtils.getSuccess(scoredList));
			return new ResponseEntity<>(responseModel, HttpStatus.OK);
		
		} catch (DataNotFoundException e) {
			throw new DataNotFoundException(e.getMessage());
		} catch (RuntimeException e) {
			throw new TException(e.getMessage());
		} catch (Exception e) {
			throw new TException(TConstants.Error.TECHNICAL_ISSUE);
		}
	}

}
