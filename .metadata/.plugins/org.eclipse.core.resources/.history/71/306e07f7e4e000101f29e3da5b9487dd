package com.medicque.adapter.out.persistence;

import java.time.LocalDateTime;
import java.util.List;
import java.util.Optional;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

import com.medicque.adapter.out.persistence.entity.Patient;
import com.medicque.adapter.out.persistence.jpa.JPAPatientRepository;
import com.medicque.application.port.out.PatientRepositoryPort;
import com.medicque.domain.model.PatientModel;

/**
 * 
 */
@Component
public class PatientRepositoryAdapter implements PatientRepositoryPort {
	
	@Autowired
	private JPAPatientRepository patientRepository;

	@Override
	public Optional<Patient> findById(Long id) {
		// TODO Auto-generated method stub
		return patientRepository.findById(id);
	}

	@Override
	public Patient save(PatientModel model) {
		// TODO Auto-generated method stub
		Patient patient = new Patient();
		
		patient.setAge(model.getAge());
		patient.setContactNumber(model.getContactNumber());
		patient.setGender(model.getGender());
		patient.setPatientId(model.getPatientId());
		patient.setUser(model.getUser());
		patient.setRelationship(model.getRelationship());
		patient.setPatientName(model.getPatientName());
		
		patient.setCreatedAt(LocalDateTime.now());
		patient.setUpdatedAt(LocalDateTime.now());
		patient.setCreatedBy(model.getCreatedBy());
		patient.setUpdatedBy(model.getUpdatedBy());
		
		patientRepository.save(patient);
		
		return patient;
	}

	@Override
	public List<Patient> findByUser_UserIdAndIsActive(Long userId, Boolean isActive) {
		// TODO Auto-generated method stub
		return patientRepository.findByUser_UserIdAndIsActive(userId, isActive);
	}

}
