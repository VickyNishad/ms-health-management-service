package com.healthcare.service;

import java.util.Map;

import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;

import com.healthcare.exception.DataNotFoundException;
import com.healthcare.interfaces.TAbstractUseCase;
import com.healthcare.interfaces.TRepository;
import com.healthcare.interfaces.usecase.TestUseCase;
import com.healthcare.models.GenericModel;
import com.healthcare.models.request.DBProcedureRequest;
import com.healthcare.models.request.TestRequest;
import com.healthcare.utils.TValidatiors;

/**
 * 
 */
@Service
public class TestServiceImpl extends TAbstractUseCase<TestRequest, DBProcedureRequest, ResponseEntity<?>> implements TestUseCase {
	
	private TRepository tRepository;
	
	public TestServiceImpl(TRepository tRepository) {
		this.tRepository = tRepository;
	}

	@Override
	protected ResponseEntity<?> validateInput(GenericModel<TestRequest> model) {
		// TODO Auto-generated method stub
		return new ResponseEntity<>(HttpStatus.OK);
	}

	@Override
	protected DBProcedureRequest buildDatabaseRequest(GenericModel<TestRequest> model) {
		// TODO Auto-generated method stub
		DBProcedureRequest dbProcedureRequest = new DBProcedureRequest();
		return dbProcedureRequest;
	}

	@Override
	protected ResponseEntity<?> execute(GenericModel<TestRequest> model, DBProcedureRequest dbRequest) {
		// TODO Auto-generated method stub
		try {
			Map<String, Object> response = tRepository.execute(dbRequest);
			if(TValidatiors.isNullOrEmpty(response)) {
				throw new RuntimeException();
			}
		} catch (RuntimeException e) {
			// TODO: handle exception
			throw new DataNotFoundException();
		}
		catch (Exception e) {
			// TODO: handle exception
		}
		return new ResponseEntity<>(HttpStatus.OK);
	}

	@Override
	protected ResponseEntity<?> buildFinalResponse(GenericModel<TestRequest> model, ResponseEntity<?> result) {
		// TODO Auto-generated method stub
		return new ResponseEntity<>(HttpStatus.OK);
	}

}
