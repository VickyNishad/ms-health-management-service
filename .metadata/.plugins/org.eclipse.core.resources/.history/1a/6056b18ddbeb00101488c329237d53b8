package com.health.adapter.out.persistence;

import java.util.Optional;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

import com.health.adapter.out.persistence.entity.Clinic;
import com.health.adapter.out.persistence.jpa.JPAClinicRepository;
import com.health.application.port.out.ClinicRepositoryPort;

/**
 * 
 */
@Component
public class ClinicRepositoryAdapter implements ClinicRepositoryPort {
	
	@Autowired
	private JPAClinicRepository clinicRepository;

	@Override
	public Clinic save(Clinic clinic) {
		// TODO Auto-generated method stub
		clinicRepository.save(clinic);
		return clinic;
	}

	@Override
	public Optional<Clinic> findById(Long clinicId) {
		// TODO Auto-generated method stub
		return clinicRepository.findById(clinicId);
	}

}
