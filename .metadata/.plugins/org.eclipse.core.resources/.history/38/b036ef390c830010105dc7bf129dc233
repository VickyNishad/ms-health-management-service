package com.document.service;

import java.util.List;
import java.util.Map;

import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;
import org.springframework.web.multipart.MultipartFile;

import com.healthcare.config.S3BucketPro;
import com.healthcare.constant.BConstants;
import com.healthcare.dto.DocumentFileDto;
import com.healthcare.dto.ResultSetResponeDto;
import com.healthcare.interfaces.AbstractUseCase;
import com.healthcare.interfaces.DocumentRepository;
import com.healthcare.interfaces.usecase.InsertDocumentUploadUseCase;
import com.healthcare.interfaces.usecase.S3BucketUseCase;
import com.healthcare.models.GenericModel;
import com.healthcare.models.request.DBProcedureRequest;
import com.healthcare.models.request.DocumentRequest;
import com.healthcare.models.request.S3BucketRequest;
import com.healthcare.models.response.DocumentInfo;
import com.healthcare.models.response.ResponseModel;
import com.healthcare.utils.BConvertors;
import com.healthcare.utils.BUtils;
import com.healthcare.utils.BValidatiors;

/**
 * 
 */
@Service
public class InsertDocumetUploadServiceImpl extends AbstractUseCase<DocumentRequest, DBProcedureRequest, DocumentInfo> implements  InsertDocumentUploadUseCase {

	private final S3BucketPro s3BucketPro;
	private S3BucketUseCase s3BucketUseCase;
	private DocumentRepository documentRepository;
	
	public InsertDocumetUploadServiceImpl (
			S3BucketUseCase s3BucketUseCase , S3BucketPro s3BucketPro,
			DocumentRepository documentRepository
			
			) {
		
		this.s3BucketUseCase = s3BucketUseCase;
		this.s3BucketPro = s3BucketPro;
		this.documentRepository = documentRepository;
	}
	
	@Override
	protected ResponseEntity<?> validateInput(GenericModel<DocumentRequest> model) {
		// TODO Auto-generated method stub
		return new ResponseEntity<>(HttpStatus.OK);
	}

	@Override
	protected DBProcedureRequest buildDatabaseRequest(GenericModel<DocumentRequest> model) {
		// TODO Auto-generated method stub
		try {
			DBProcedureRequest dbProcedureRequest = new DBProcedureRequest();
			DocumentRequest documentRequest = model.getPayload();
			MultipartFile file = documentRequest.getMultipartFile();
			
			String key = "file/" + documentRequest.getReferenceId() + "/"+ BUtils.getFileName(documentRequest.getFileName(), file);
			
			S3BucketRequest s3BucketRequest = new S3BucketRequest();
			s3BucketRequest.setKey(key);
			s3BucketRequest.setMultipartFile(file);
			
			GenericModel<S3BucketRequest> genericModel = new GenericModel<S3BucketRequest>();
			genericModel.setPayload(s3BucketRequest);
			
			ResponseEntity<?> responseEntity = s3BucketUseCase.handle(genericModel);
			if(responseEntity.getStatusCode().is2xxSuccessful()) {
				
				DocumentFileDto documentFileDto = new DocumentFileDto();
				
				String fileSize = String.format("%.2f KB", (double) file.getSize() / 1024);
				
				documentFileDto.setContentType(file.getContentType());		
				documentFileDto.setFileName(BUtils.getFileName(documentRequest.getFileName(), file));
				documentFileDto.setFilePath(key);
				documentFileDto.setFileSize(fileSize);
				documentFileDto.setFileType(documentRequest.getFileType());
				documentFileDto.setReferenceType(documentRequest.getReferenceType().toUpperCase());
				documentFileDto.setReferenceId(documentRequest.getReferenceId());
				documentFileDto.setS3BucketKey(s3BucketPro.getAccessKey());
				documentFileDto.setS3BucketName(s3BucketPro.getBucketName());
				
				
				String json = BConvertors.convertObjectToString(documentFileDto);
				dbProcedureRequest.setParam_JSON(json);
				dbProcedureRequest.setParam_Process(BConstants.ParamProcess.INSERT_DOCUMENT);
				dbProcedureRequest.setTokenId("");
				
				return dbProcedureRequest;
			} else {
				throw new RuntimeException("");
			}
		} catch (RuntimeException e) {
			// TODO: handle exception
			throw new RuntimeException("");
		}
		
	}

	@Override
	protected DocumentInfo execute(GenericModel<DocumentRequest> model, DBProcedureRequest dbRequest) {
		// TODO Auto-generated method stub
		Map<String, Object> response = documentRepository.execute(dbRequest);
		if(BValidatiors.isNullOrEmpty(response)) {
			return null;
		}
		List<Map<String, Object>> resultset1 = (List<Map<String, Object>>) response.get(BConstants.ResultSet.RESULT_SET_1);
		if(resultset1.isEmpty() || resultset1.size()==0) {
			return null;
		}
		ResultSetResponeDto resultSetResponeDto = BConvertors.convertObjectToPojo(resultset1.get(0), ResultSetResponeDto.class);
		if(resultSetResponeDto.getResult().equalsIgnoreCase(BConstants.Keys.ERROR)) {
			return null;
		}
		
		List<Map<String, Object>> resultset2 = (List<Map<String, Object>>) response.get(BConstants.ResultSet.RESULT_SET_2);
		if(resultset2.isEmpty() || resultset2.size()==0) {
			return null;
		}
		
		DocumentInfo documentInfo = BConvertors.convertObjectToPojo(resultset2.get(0), DocumentInfo.class);
		return documentInfo ;
	}

	@Override
	protected ResponseEntity<?> buildFinalResponse(GenericModel<DocumentRequest> model, DocumentInfo documentInfo) {
		// TODO Auto-generated method stub
		ResponseModel responseModel = null;
		responseModel = new ResponseModel(BConstants.Keys.SUCCESS, BUtils.getSuccess(documentInfo));
		
		return new ResponseEntity<>(responseModel,HttpStatus.OK);
	}

}
