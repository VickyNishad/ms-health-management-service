package com.healthcare.interfaces;

import org.springframework.http.ResponseEntity;

import com.healthcare.interfaces.usecase.TUseCase;
import com.healthcare.models.GenericModel;

public abstract class TAbstractUseCase<T, DBRequest, Response> implements TUseCase<T> {

    @Override
    public ResponseEntity<?> handle(GenericModel<T> model) {
        ResponseEntity<?> validation = validateInput(model);
        if (!validation.getStatusCode().is2xxSuccessful()) return validation;

        DBRequest dbRequest = buildDatabaseRequest(model);
        Response dbResult = execute(model, dbRequest);
        return buildFinalResponse(model, dbResult);
    }

    protected abstract ResponseEntity<?> validateInput(GenericModel<T> model);
    protected abstract DBRequest buildDatabaseRequest(GenericModel<T> model);
    protected abstract Response execute(GenericModel<T> model, DBRequest dbRequest);
    protected abstract ResponseEntity<?> buildFinalResponse(GenericModel<T> model, Response result);
}
