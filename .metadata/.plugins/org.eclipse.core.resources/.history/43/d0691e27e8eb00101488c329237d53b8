		}, ApiResponse::success);
		return createUpdateLeaveOrBreak(leave.getData(), doctorLeaveRequest);
	}

	@Override
	public ResponseEntity<ApiResponse<MessageResponse>> createUpdateLeaveOrBreak(DoctorLeave existingLeave,DoctorLeaveRequest doctorLeaveRequest) {
		// TODO Auto-generated method stub
		ApiResponse<MessageResponse> success = ApiExecutionUtils.ApiExecutor.processRequest(doctorLeaveRequest, req->{}, ()->{
	        Doctor doctor = doctorRepositoryService.findById(doctorLeaveRequest.getDoctorId())
	                .orElseThrow(() -> new RuntimeException("Doctor not found"));
	        
	        boolean isUpdate = existingLeave != null;
	        
	        // VALIDATION — date range
	        if (doctorLeaveRequest.getEndDate().isBefore(doctorLeaveRequest.getStartDate())) {
	        	throw new RuntimeException("End date cannot be before start date.");
	        }

//	        // NON full-day needs time
	        if (!doctorLeaveRequest.getLeaveType().equals("FULL_DAY")) {
	            if (doctorLeaveRequest.getStartTime() == null || doctorLeaveRequest.getEndTime() == null) {
	            	throw new RuntimeException("StartTime and EndTime required for BREAK/LUNCH/HALF_DAY");
	            }
	        }
	        	        
			List<DoctorLeave> overlaps = doctorLeaveRepository.findOverlappingLeaves(
					doctorLeaveRequest.getDoctorId(), 
					doctorLeaveRequest.getStartDate(),
					doctorLeaveRequest.getEndDate());
			
			if (isUpdate) {
	            overlaps.removeIf(l -> l.getLeave_id().equals(existingLeave.getLeave_id()));
	        }

	        if (!overlaps.isEmpty()) {
	        	throw new RuntimeException("Leave already exists in this range.");
	        }
	        
	        
	     // OBJECT CREATE / UPDATE
	        DoctorLeave leave = isUpdate ? existingLeave : new DoctorLeave();

	        leave.setDoctor(doctor);
	        leave.setLeaveType(doctorLeaveRequest.getLeaveType());
	        leave.setStartDate(doctorLeaveRequest.getStartDate());
	        leave.setEndDate(doctorLeaveRequest.getEndDate());

	        if (doctorLeaveRequest.getLeaveType().equals("FULL_DAY")) {
	            leave.setStartTime(LocalTime.of(0, 0));
	            leave.setEndTime(LocalTime.of(23, 59));
	        } else {
	            leave.setStartTime(doctorLeaveRequest.getStartTime());
	            leave.setEndTime(doctorLeaveRequest.getEndTime());
	        }

	        leave.setReason(doctorLeaveRequest.getReason());
	        leave.setIsActive(true);
	        
	        DoctorLeaveModel leaveModel = new DoctorLeaveModel();
	        leaveModel.setLeave_id(leave.getLeave_id());
	        leaveModel.setLeaveType(leave.getLeaveType());
	        leaveModel.setStartDate(leave.getStartDate());
	        leaveModel.setEndDate(leave.getEndDate());
	        leaveModel.setStartTime(leave.getStartTime());
	        leaveModel.setEndTime(leave.getEndTime());
	        leaveModel.setLeaveType(leave.getLeaveType());
	        leaveModel.setReason(leave.getReason());
	        leaveModel.setDoctor_id(leave.getDoctor());
	        leaveModel.setCreatedAt(leave.getCreatedAt());
	        leaveModel.setCreatedBy(leave.getCreatedBy());
	        leaveModel.setUpdatedAt(leave.getUpdatedAt());
	        leaveModel.setUpdatedAt(leave.getUpdatedAt());
	        leaveModel.setIsActive(leave.getIsActive());
	       
	        doctorLeaveRepository.save(leaveModel);

	        return new MessageResponse(isUpdate ? "Leave updated successfully" : "Leave added successfully");
		}, ApiResponse::success);
		return new ResponseEntity<ApiResponse<MessageResponse>>(success, HttpStatus.OK);
	}

	@Override
	public ResponseEntity<ApiResponse<List<DoctorLeaveResponse>>> getDoctorLeaves(Long doctorId) {
		// TODO Auto-generated method stub
		ApiResponse<List<DoctorLeaveResponse>> success = ApiExecutionUtils.ApiExecutor.processRequest(doctorId,
				req->{
//					if(doctorId==null) {
//						
//					}
				},
				()->{
					List<DoctorLeaveResponse> leaveRes = new ArrayList<>();
					DoctorLeaveResponse response = new DoctorLeaveResponse();
					List<DoctorLeave> leaves = doctorLeaveRepository.getDoctorLeaves(doctorId);
					for(DoctorLeave leave : leaves) {
						response = new DoctorLeaveResponse();
						response.setDoctor_id(leave.getDoctor().getDoctorId());
						response.setEndDate(leave.getEndDate());
						response.setEndTime(leave.getEndTime());
						response.setLeave_id(leave.getLeave_id());
						response.setLeaveType(leave.getLeaveType());
						response.setReason(leave.getReason());
						response.setStartDate(leave.getStartDate());
						response.setStartTime(leave.getStartTime());
						leaveRes.add(response);
					}
					return leaveRes;
					}, ApiResponse::success);
		return new ResponseEntity<ApiResponse<List<DoctorLeaveResponse>>>(success, HttpStatus.OK);
	}

	@Override
	public ResponseEntity<ApiResponse<MessageResponse>> insertDoctorAvailability(Long doctorId, Long clinicId,DoctorAvailabilityRequest doctorAvailabilityRequest) {
		// TODO Auto-generated method stub
		ApiResponse<MessageResponse> success = ApiExecutionUtils.ApiExecutor.processRequest(null, 
				req->{}, 
				()->{
			        // Validate doctor & clinic
			        Doctor doctor = doctorRepositoryService.findById(doctorId).orElseThrow(() -> new RuntimeException("Doctor not found"));

			        Clinic clinic = clinicRepository.findById(clinicId).orElseThrow(() -> new RuntimeException("Clinic not found"));
			        

			        // Time parsing
			        LocalTime startTime = LocalTime.parse(doctorAvailabilityRequest.getStartTime());
			        LocalTime endTime = LocalTime.parse(doctorAvailabilityRequest.getEndTime());

			        if (!startTime.isBefore(endTime)) {
			            throw new RuntimeException("Start time must be before end time.");
			        }

			        String day = doctorAvailabilityRequest.getDayOfWeek();
			        
			        // -------------------------------
			        // VALIDATION A: SAME CLINIC
			        // -------------------------------
			        List<DoctorAvailability> sameClinicList = doctorAvailabilityRepository.findByDoctor_DoctorIdAndClinic_ClinicIdAndDayOfWeek(doctorId, clinicId, day);

			        for (DoctorAvailability a : sameClinicList) {
			        	if(day.equalsIgnoreCase(a.getDayOfWeek()))
			            if (isOverlap(startTime, endTime,
			                    LocalTime.parse(a.getStartTime()), LocalTime.parse(a.getEndTime()))) {
			                throw new RuntimeException("Overlapping availability in same clinic.");
			            }
			        }
			        
			        
			        // -------------------------------
			        // VALIDATION B: OTHER CLINICS
			        // -------------------------------
			        List<DoctorAvailability> otherClinics = doctorAvailabilityRepository.findByDoctor_DoctorIdAndDayOfWeek(doctorId, day);

			        for (DoctorAvailability a : otherClinics) {

			            if (!a.getClinic().getClinicId().equals(clinicId)) { // other clinic only

			                if (isOverlap(startTime, endTime,
			                        LocalTime.parse(a.getStartTime()), LocalTime.parse(a.getEndTime()))) {
			                    throw new RuntimeException("Doctor already available in another clinic at this time.");
			                }
			            }
			        }

					// -------------------------------
					// SAVE FINAL RECORD
					// -------------------------------

					DoctorAvailabilityModel doctorAvailabilityModel = new DoctorAvailabilityModel();

					doctorAvailabilityModel.setClinic(clinic);
					doctorAvailabilityModel.setDoctor(doctor);

					doctorAvailabilityModel.setStartTime(doctorAvailabilityRequest.getStartTime());
					doctorAvailabilityModel.setEndTime(doctorAvailabilityRequest.getEndTime());
					doctorAvailabilityModel.setSlotDuration(doctorAvailabilityRequest.getSlotDuration());
					doctorAvailabilityModel.setDayOfWeek(day);

					doctorAvailabilityModel.setCreatedAt(LocalDateTime.now());
					doctorAvailabilityModel.setCreatedBy(doctorId.toString());
					doctorAvailabilityModel.setUpdatedAt(null);
					doctorAvailabilityModel.setUpdatedBy(doctorId.toString());
					doctorAvailabilityModel.setIsActive(true);
					doctorAvailabilityRepository.save(doctorAvailabilityModel);

					return new MessageResponse("Availability added successfully.");
					
				}, ApiResponse::success);
		return new ResponseEntity<ApiResponse<MessageResponse>>(success, HttpStatus.OK);
	}
	

	@Override
	public ResponseEntity<ApiResponse<MessageResponse>> updateDoctorAvailability(Long doctorId,DoctorAvailabilityUpdateRequest doctorAvailabilityUpdateRequest) {
		// TODO Auto-generated method stub
		ApiResponse<MessageResponse> success = ApiExecutionUtils.ApiExecutor.processRequest(null, 
				req->{}, 
				()->{
					
				    Doctor doctor = doctorRepositoryService.findById(doctorId)
				            .orElseThrow(() -> new RuntimeException("Doctor not found."));

				    Clinic clinic = clinicRepository.findById(doctorAvailabilityUpdateRequest.getClinicId())
				            .orElseThrow(() -> new RuntimeException("Clinic not found."));

				    String day = doctorAvailabilityUpdateRequest.getDayOfWeek();

				    // 1️⃣ Delete old availability
				    List<DoctorAvailability> oldList =
				    		doctorAvailabilityRepository.findByDoctor_DoctorIdAndClinic_ClinicIdAndDayOfWeek(
				                    doctorId, doctorAvailabilityUpdateRequest.getClinicId(), day);

				    doctorAvailabilityRepository.deleteAll(oldList);

				    // 2️⃣ Insert new availability items
				    for (DoctorAvailabilityRequest item : doctorAvailabilityUpdateRequest.getAvailabilityList()) {

				        LocalTime newStart = LocalTime.parse(item.getStartTime());
				        LocalTime newEnd = LocalTime.parse(item.getEndTime());

				        if (!newStart.isBefore(newEnd)) {
				            throw new RuntimeException("Start time must be before end time.");
				        }

				        // CHECK AGAINST OTHER CLINICS
				        List<DoctorAvailability> otherClinics =
				        		doctorAvailabilityRepository.findByDoctor_DoctorIdAndDayOfWeek(doctorId, day);

				        for (DoctorAvailability av : otherClinics) {
				            if (!av.getClinic().getClinicId().equals(doctorAvailabilityUpdateRequest.getClinicId())) {
				                LocalTime oldStart = LocalTime.parse(av.getStartTime());
				                LocalTime oldEnd = LocalTime.parse(av.getEndTime());

				                if (isOverlap(newStart, newEnd, oldStart, oldEnd)) {
				                    throw new RuntimeException(
				                            "Doctor already available in another clinic at this time.");
				                }
				            }
				        }

						DoctorAvailabilityModel doctorAvailabilityModel = new DoctorAvailabilityModel();

						doctorAvailabilityModel.setClinic(clinic);
						doctorAvailabilityModel.setDoctor(doctor);

						doctorAvailabilityModel.setStartTime(item.getStartTime());
						doctorAvailabilityModel.setEndTime(item.getEndTime());
						doctorAvailabilityModel.setSlotDuration(item.getSlotDuration());
						doctorAvailabilityModel.setDayOfWeek(day);

						doctorAvailabilityModel.setUpdatedAt(LocalDateTime.now());
						doctorAvailabilityModel.setUpdatedBy(doctorId.toString());
						doctorAvailabilityModel.setIsActive(true);
						doctorAvailabilityRepository.save(doctorAvailabilityModel);
				    }
						return new MessageResponse("Availability updated successfully.");
					},
				ApiResponse::success);
		return new ResponseEntity<ApiResponse<MessageResponse>>(success, HttpStatus.OK);
	}

		// -------------------------------
		// HELPER: OVERLAP LOGIC
		// -------------------------------
		private boolean isOverlap(LocalTime s1, LocalTime e1, LocalTime s2, LocalTime e2) {
			    return !(e1.isBefore(s2) || s1.isAfter(e2));
		}

		@Override
		public ResponseEntity<ApiResponse<List<AvailabilityResponse>>> getDoctorAvailability(Long doctorId) {
			// TODO Auto-generated method stub
			ApiResponse<List<AvailabilityResponse>> success = ApiExecutionUtils.ApiExecutor.processRequest(null, 
					req->{}, 
					()->{        // Fetch all availability records for the doctor
				        List<DoctorAvailability> all = doctorAvailabilityRepository
				                .findByDoctor_DoctorIdOrderByDayOfWeekAscStartTimeAsc(doctorId);

				        // Convert entity → response DTO
				        return all.stream()
				                .map(a -> new AvailabilityResponse(
				                        a.getAvailabilityId(),
				                        a.getClinic().getClinicId(),			                     
				                        a.getStartTime(),
				                        a.getEndTime(),
				                        a.getDayOfWeek(),
				                        a.getSlotDuration()
				                ))
				                .collect(Collectors.toList());
					}, 
					ApiResponse::success);
					
			return new ResponseEntity<ApiResponse<List<AvailabilityResponse>>>(success, HttpStatus.OK);
		}

		@Override
		public ResponseEntity<ApiResponse<MessageResponse>> deleteAvailability(Long doctorId, Long availabilityId) {
			// TODO Auto-generated method stub
			ApiResponse<MessageResponse> success = ApiExecutionUtils.ApiExecutor.processRequest(null, req -> {
			}, () -> {
				DoctorAvailability availability = doctorAvailabilityRepository.findById(availabilityId)
						.orElseThrow(() -> new RuntimeException("Availability not found."));

				if (!availability.getDoctor().getDoctorId().equals(doctorId)) {
					throw new RuntimeException("You cannot delete someone else’s availability.");
				}

				doctorAvailabilityRepository.deleteById(availabilityId);
				return new MessageResponse("Availability removed successfully.");
			}, ApiResponse::success);
			return new ResponseEntity<ApiResponse<MessageResponse>>(success, HttpStatus.OK);
		}

