package com.bittybrain.exception;

public class BittyBrainException extends RuntimeException {
	/**
	 * 
	 */
	private static final long serialVersionUID = 1L;

	public BittyBrainException(String message) {
		super(message);
	}

	public BittyBrainException(String message, Throwable cause) {
		super(message, cause);
	}
}
