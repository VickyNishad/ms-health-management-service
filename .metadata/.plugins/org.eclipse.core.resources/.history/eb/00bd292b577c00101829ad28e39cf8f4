package com.document.controller;

import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.ModelAttribute;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.document.interfaces.usecase.GetDocumentFileUseCase;
import com.document.interfaces.usecase.InsertDocumentUploadUseCase;
import com.document.models.GenericModel;
import com.document.models.request.DocumentRequest;

/**
 * 
 */
@RestController
@RequestMapping(DocumentController.BASE_URL)
public class DocumentController {
	
	public static final String BASE_URL = "api/v1/document/file";
	
	private InsertDocumentUploadUseCase insertDocumentUploadUseCase;
	private GetDocumentFileUseCase getDocumentFileUseCase;
	
	public DocumentController(InsertDocumentUploadUseCase insertDocumentUploadUseCase, GetDocumentFileUseCase getDocumentFileUseCase) {
		this.insertDocumentUploadUseCase = insertDocumentUploadUseCase;
		this.getDocumentFileUseCase = getDocumentFileUseCase;
	}


	@PostMapping(value = "/upload", consumes = "multipart/form-data")
	public ResponseEntity<?> uploadDocument(@ModelAttribute DocumentRequest documentRequest) {
		GenericModel<DocumentRequest> genericModel = new GenericModel<DocumentRequest>();
		genericModel.setPayload(documentRequest);		
		return insertDocumentUploadUseCase.handle(genericModel);
	}
	
	@GetMapping("/{id}")
	public ResponseEntity<?> getDocumentFile( @PathVariable("id") String id) {
		GenericModel<String> genericModel = new GenericModel<String>();
		genericModel.setPayload(id);		
		return getDocumentFileUseCase.handle(genericModel);
	}

}
