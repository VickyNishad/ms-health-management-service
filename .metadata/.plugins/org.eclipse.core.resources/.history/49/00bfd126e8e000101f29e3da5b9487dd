package com.medicque.adapter.in.rest;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.common.models.ApiResponse;
import com.medicque.adapter.in.rest.dto.FamilyMemberRequest;
import com.medicque.adapter.in.rest.dto.MessageResponse;
import com.medicque.adapter.out.persistence.entity.FamilyMember;
import com.medicque.application.port.in.FamilyMemberUseCase;


/**
 * 
 */

@RestController
@RequestMapping("/medicque/familymember")
public class FamilyMemberController {

	@Autowired
	private FamilyMemberUseCase familyMemberUseCase;
	
	@PostMapping("/add/{userId}")
	public ResponseEntity<ApiResponse<FamilyMember>> addFamilyMember(@PathVariable(name = "userId") Long userId,@RequestBody FamilyMemberRequest familyMemberRequest){
		return familyMemberUseCase.addFamilyMember(userId, familyMemberRequest);
	}
	
	@GetMapping("/{userId}")
	public ResponseEntity<ApiResponse<List<FamilyMember>>> getFamilyMember(@PathVariable(name = "userId") Long userId){
		return familyMemberUseCase.getFamilyMember(userId);
	}
	
	@PostMapping("/modify/{userId}/{familyMemebrId}")
	public ResponseEntity<ApiResponse<FamilyMember>> modifyFamilyMember(@PathVariable(name = "userId") Long userId,@PathVariable(name = "familyMemebrId") Long familyMemebrId ,@RequestBody FamilyMemberRequest familyMemberRequest){
		return familyMemberUseCase.modifyFamilyMember(userId, familyMemebrId, familyMemberRequest);
	}
	
	@DeleteMapping("/remove/{userId}/{familyMemebrId}")
	public ResponseEntity<ApiResponse<MessageResponse>> removeFamilyMember(@PathVariable(name = "userId") Long userId,@PathVariable(name = "familyMemebrId") Long familyMemebrId){
		return familyMemberUseCase.removeFamilyMember(userId, familyMemebrId);
	}
}
